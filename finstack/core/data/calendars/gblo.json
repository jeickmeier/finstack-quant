{
  "id": "gblo",
  "name": "United Kingdom (London) Holiday Calendar",
  "ignore_weekends": false,
  "notes": "Christmas/Boxing Day use chained substitution (mon_if_sat_tue_if_sun): each moves two days when on a weekend so the two observed days never collide (2021: Mon 27 + Tue 28 Dec; 2022: Mon 26 + Tue 27 Dec). One-off bank holidays and moved May bank holidays per UK government history (gov.uk/bank-holidays): 2012 Diamond Jubilee (Spring BH moved to Jun 4 + extra Jun 5), 2020 VE Day (Early May BH moved to May 8), 2022 Platinum Jubilee (Spring BH moved to Jun 2 + extra Jun 3), 2022-09-19 State Funeral of Queen Elizabeth II, 2023-05-08 Coronation of King Charles III.",
  "rules": [
    { "type": "fixed", "name": "New Year's Day", "month": "january", "day": 1, "observed": "next_monday" },
    { "type": "fixed", "name": "Christmas Day", "month": "december", "day": 25, "observed": "mon_if_sat_tue_if_sun" },
    { "type": "fixed", "name": "Boxing Day", "month": "december", "day": 26, "observed": "mon_if_sat_tue_if_sun" },
    { "type": "easter_offset", "name": "Good Friday", "days": -3 },
    { "type": "easter_offset", "name": "Easter Monday", "days": 0 },
    { "type": "nth_weekday", "name": "Early May Bank Holiday", "n": 1, "weekday": "monday", "month": "may", "to_year": 2019 },
    { "type": "nth_weekday", "name": "Early May Bank Holiday", "n": 1, "weekday": "monday", "month": "may", "from_year": 2021 },
    { "type": "fixed", "name": "Early May Bank Holiday (moved for VE Day 75th anniversary)", "month": "may", "day": 8, "from_year": 2020, "to_year": 2020 },
    { "type": "nth_weekday", "name": "Spring Bank Holiday", "n": -1, "weekday": "monday", "month": "may", "to_year": 2011 },
    { "type": "nth_weekday", "name": "Spring Bank Holiday", "n": -1, "weekday": "monday", "month": "may", "from_year": 2013, "to_year": 2021 },
    { "type": "nth_weekday", "name": "Spring Bank Holiday", "n": -1, "weekday": "monday", "month": "may", "from_year": 2023 },
    { "type": "fixed", "name": "Spring Bank Holiday (moved for Diamond Jubilee)", "month": "june", "day": 4, "from_year": 2012, "to_year": 2012 },
    { "type": "fixed", "name": "Queen's Diamond Jubilee", "month": "june", "day": 5, "from_year": 2012, "to_year": 2012 },
    { "type": "fixed", "name": "Spring Bank Holiday (moved for Platinum Jubilee)", "month": "june", "day": 2, "from_year": 2022, "to_year": 2022 },
    { "type": "fixed", "name": "Queen's Platinum Jubilee", "month": "june", "day": 3, "from_year": 2022, "to_year": 2022 },
    { "type": "fixed", "name": "State Funeral of Queen Elizabeth II", "month": "september", "day": 19, "from_year": 2022, "to_year": 2022 },
    { "type": "fixed", "name": "Coronation of King Charles III", "month": "may", "day": 8, "from_year": 2023, "to_year": 2023 },
    { "type": "nth_weekday", "name": "Summer Bank Holiday", "n": -1, "weekday": "monday", "month": "august" }
  ]
}
