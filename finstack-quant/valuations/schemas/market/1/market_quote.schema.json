      ],
      "type": "object"
    },
    {
      "description": "CDS Tranches",
      "oneOf": [
        {
          "description": "CDS Index Tranche.",
          "properties": {
            "attachment": {
              "description": "Attachment point (decimal, e.g. 0.03).",
              "format": "double",
              "type": "number"
            },
            "convention": {
              "$ref": "#/$defs/CdsConventionKey",
              "description": "Convention key (currency + doc clause)."
            },
            "detachment": {
              "description": "Detachment point (decimal, e.g. 0.07).",
              "format": "double",
              "type": "number"
            },
            "id": {
              "$ref": "#/$defs/QuoteId",
              "description": "Unique identifier."
            },
            "index": {
              "description": "Index identifier (e.g. CDX.NA.HY).",
