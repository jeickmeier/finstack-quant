            },
            "maturity": {
              "description": "Maturity date.",
              "format": "date",
              "type": "string"
            },
            "running_spread_bp": {
              "description": "Running spread (bps).",
              "format": "double",
              "type": "number"
            },
            "type": {
              "const": "cds_tranche",
              "type": "string"
            },
            "upfront_pct": {
              "description": "Upfront payment as a decimal fraction of tranche notional (e.g., -0.025 for -2.5%).",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "type",
            "id",
            "index",
            "attachment",
            "detachment",
            "maturity",
            "upfront_pct",
            "running_spread_bp",
            "convention"
          ],
          "type": "object"
        }
      ],
      "properties": {
        "class": {
          "const": "cds_tranche",
          "type": "string"
        }
      },
      "required": [
        "class"
      ],
      "type": "object"
    },
    {
      "description": "FX instruments",
      "oneOf": [
        {
          "description": "Outright FX forward quote quoted as quote-currency per base-currency.",
          "properties": {
            "convention": {
              "$ref": "#/$defs/FxConventionId",
              "description": "FX pair convention identifier (e.g., `EUR/USD`)."
            },
            "forward_rate": {
              "description": "Forward outright quoted as quote-currency per base-currency.",
              "format": "double",
              "type": "number"
            },
            "id": {
              "$ref": "#/$defs/QuoteId",
              "description": "Unique identifier for the quote."
            },
            "pillar": {
              "$ref": "#/$defs/Pillar",
              "description": "Maturity pillar for the forward settlement date."
            },
