{
  "$defs": {
    "ExerciseStyle": {
      "description": "Exercise style for options",
      "oneOf": [
        {
          "const": "european",
          "description": "European exercise (only at expiry)",
          "type": "string"
        },
        {
          "const": "american",
          "description": "American exercise (any time before/at expiry)",
          "type": "string"
        },
        {
          "const": "bermudan",
          "description": "Bermudan exercise (specific dates before expiry)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "SettlementType": {
      "description": "Settlement type for options",
      "oneOf": [
        {
          "const": "physical",
          "description": "Physical delivery",
          "type": "string"
        },
        {
          "const": "cash",
          "description": "Cash settlement",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/equity_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Vanilla equity option with European or American exercise",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "discrete_dividends": [],
          "div_yield_id": "EQUITY-DIVYIELD",
          "exercise_style": "european",
          "expiry": "2024-06-21",
          "id": "SPX-CALL-4500",
          "notional": {
            "amount": "100",
            "currency": "USD"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "settlement": "cash",
          "spot_id": "EQUITY-SPOT",
          "strike": 4500.0,
          "underlying_ticker": "SPX",
          "vol_surface_id": "EQUITY-VOL"
        },
        "type": "equity_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Equity Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "default": "Act365F",
              "description": "Day count convention"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "discrete_dividends": {
              "default": [],
              "description": "Optional discrete dividend schedule for more accurate pricing.\n\nEach entry is (ex-date, dividend_amount). When provided, the escrowed\ndividend model is used: the spot price is adjusted by subtracting the\nPV of future dividends before option pricing.\n\n# Escrowed Dividend Model\n\nThe adjusted spot is:\n```text\nS* = S - Σ D_i × DF(t_i)\n```\nwhere D_i is each dividend amount and DF(t_i) is the discount factor\nto the ex-date. The adjusted spot S* is then used in Black-Scholes\nwith zero dividend yield.\n\n# Reference\n\n- Haug, Haug, Lewis (2003). \"Back to Basics: a new approach to the\n  discrete dividend problem\"",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional continuous dividend yield identifier.\n\nThe dividend yield should be a unitless scalar representing the annualized\ncontinuous dividend yield (e.g., 0.02 for 2%). This is used in the BSM model\nas the `q` parameter: `d1 = (ln(S/K) + (r - q + σ²/2)T) / (σ√T)`.\n\n# Semantics by value\n\n- **`Some(id)`** — the lookup MUST succeed. A missing market scalar\n  (or a non-unitless type) returns a hard error rather than silently\n  defaulting to zero, preventing market-data configuration errors\n  from quietly distorting P&L.\n- **`None`** — there is *no implicit default curve*. The pricer treats\n  the underlying as having **zero continuous dividend yield**. This is\n  correct for non-dividend-paying single stocks; for index options\n  (typically ~2% yield) callers should set `div_yield_id` explicitly.\n\nIf `discrete_dividends` is non-empty, an escrowed-dividend adjustment\nis applied to spot and `q` is set to 0 internally regardless of\n`div_yield_id`."
            },
            "exercise_schedule": {
              "description": "Exercise schedule for Bermudan options.\n\nRequired when `exercise_style` is `Bermudan`. Each date represents a time\nat which early exercise is permitted. Dates before as_of or after expiry\nare filtered out automatically.",
              "items": {
                "type": "string"
              },
              "type": [
                "array",
                "null"
              ]
            },
            "exercise_style": {
              "$ref": "#/$defs/ExerciseStyle",
              "default": "european",
              "description": "Exercise style (European or American)"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount for valuation scaling."
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "settlement": {
              "$ref": "#/$defs/SettlementType",
              "default": "cash",
              "description": "Settlement type (physical or cash)"
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Equity spot price identifier"
            },
            "strike": {
              "description": "Strike price",
              "format": "double",
              "type": "number"
            },
            "underlying_ticker": {
              "description": "Underlying equity ticker symbol",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Equity volatility surface ID"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "strike",
            "option_type",
            "expiry",
            "notional",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "equity_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Equity Option",
  "type": "object"
}
