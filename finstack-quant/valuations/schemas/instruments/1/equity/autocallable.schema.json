{
  "$defs": {
    "FinalPayoffType": {
      "description": "Final payoff type for autocallable products.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "Capital protection: max(floor, participation * min(S_T/S_0, cap))",
          "properties": {
            "CapitalProtection": {
              "properties": {
                "floor": {
                  "description": "Minimum return floor (e.g., 1.0 for 100% protection)",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "floor"
              ],
              "type": "object"
            }
          },
          "required": [
            "CapitalProtection"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Participation: 1 + participation_rate * max(0, S_T/S_0 - 1)",
          "properties": {
            "Participation": {
              "properties": {
                "rate": {
                  "description": "Participation rate in upside (e.g., 1.0 for 100% participation)",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "rate"
              ],
              "type": "object"
            }
          },
          "required": [
            "Participation"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Knock-in put: Put option if barrier breached, otherwise return principal",
          "properties": {
            "KnockInPut": {
              "properties": {
                "strike": {
                  "description": "Strike price for knock-in put option",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "strike"
              ],
              "type": "object"
            }
          },
          "required": [
            "KnockInPut"
          ],
          "type": "object"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/autocallable.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Autocallable structured product with observation schedule",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "autocall_barriers": [
            1.0,
            1.0,
            1.0,
            1.0
          ],
          "cap_level": 1.5,
          "coupons": [
            0.02,
            0.02,
            0.02,
            0.02
          ],
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "div_yield_id": "SPX-DIV",
          "expiry": "2024-12-31",
          "final_barrier": 0.6,
          "final_payoff_type": {
            "Participation": {
              "rate": 1.0
            }
          },
          "id": "AUTO-SPX-QTR",
          "notional": {
            "amount": "100000",
            "currency": "USD"
          },
          "observation_dates": [
            "2024-03-29",
            "2024-06-28",
            "2024-09-30",
            "2024-12-31"
          ],
          "participation_rate": 1.0,
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "spot_id": "SPX-SPOT",
          "underlying_ticker": "SPX",
          "vol_surface_id": "SPX-VOL"
        },
        "type": "autocallable"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Autocallable instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "autocall_barriers": {
              "description": "Autocall barrier levels (as ratios of initial spot, e.g., 1.0 = 100%).\n\nEach barrier corresponds to the observation date at the same index.\nIf spot ≥ barrier × initial_spot on the observation date, the product autocalls.",
              "items": {
                "format": "double",
                "type": "number"
              },
              "type": "array"
            },
            "cap_level": {
              "description": "Cap level for final payoff (maximum return)",
              "format": "double",
              "type": "number"
            },
            "coupons": {
              "description": "Coupon amounts paid if observation barrier is met",
              "items": {
                "format": "double",
                "type": "number"
              },
              "type": "array"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention for interest calculations"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dividend yield curve ID.\n\n`Some(id)`: lookup MUST succeed (a missing or non-unitless scalar\nreturns an error). `None`: no implicit default; treated as zero\ncontinuous dividend yield. Set explicitly for index underlyings."
            },
            "expiry": {
              "description": "Explicit terminal expiry date for the structure.",
              "format": "date",
              "type": "string"
            },
            "final_barrier": {
              "description": "Final barrier level for final payoff determination",
              "format": "double",
              "type": "number"
            },
            "final_payoff_type": {
              "$ref": "#/$defs/FinalPayoffType",
              "description": "Type of final payoff (capital protection, participation, knock-in put)"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "initial_level": {
              "default": null,
              "description": "Initial (strike-set) underlying level S_0 used as the reference for\nbarrier and payoff ratios.\n\n`None` (the default) uses the spot at the valuation date, which is only\ncorrect for a new trade priced on its strike-set date. **Required for\nseasoned trades** (any observation date on or before `as_of`): pricing\nerrors if past observation dates exist without it.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "memory_coupons": {
              "default": false,
              "description": "Memory (\"Phoenix\") coupon feature.\n\nWhen `true`, any coupons from earlier observation dates whose barrier\nwas *not* met are accrued (\"remembered\") and paid in full on the\nobservation date that finally triggers the autocall (in addition to\nthat date's own coupon). When `false` (the default), only the coupon\nat the autocall date is paid and earlier missed coupons are lost.\n\nThis flag must match the term sheet: a Phoenix/memory autocallable\npriced with `memory_coupons = false` is silently underpriced.",
              "type": "boolean"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "observation_dates": {
              "description": "Observation dates for autocall and coupon checks.\n\nBarriers are monitored **discretely** at these exact dates only.\nThe Monte Carlo time grid is constructed to include these dates precisely.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "participation_rate": {
              "description": "Participation rate in underlying performance",
              "format": "double",
              "type": "number"
            },
            "past_fixings": {
              "default": [],
              "description": "Observed underlying fixings for seasoned trades (date, level pairs).\n\nFor a mid-life autocallable, every observation date on or before the\nvaluation date must have a matching fixing here; pricing errors\notherwise. Past fixings are evaluated deterministically (autocall,\nmissed memory coupons, discrete knock-in monitoring) and only the\nremaining future observation dates are simulated.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Spot price identifier for underlying asset"
            },
            "underlying_ticker": {
              "description": "Underlying asset ticker symbol",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for option pricing"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "observation_dates",
            "expiry",
            "autocall_barriers",
            "coupons",
            "final_barrier",
            "final_payoff_type",
            "participation_rate",
            "cap_level",
            "notional",
            "day_count",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "autocallable",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Autocallable",
  "type": "object"
}
