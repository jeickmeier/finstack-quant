{
  "$defs": {
    "ExerciseStyle": {
      "description": "Exercise style for options",
      "oneOf": [
        {
          "const": "european",
          "description": "European exercise (only at expiry)",
          "type": "string"
        },
        {
          "const": "american",
          "description": "American exercise (any time before/at expiry)",
          "type": "string"
        },
        {
          "const": "bermudan",
          "description": "Bermudan exercise (specific dates before expiry)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "VolIndexOptionSpecs": {
      "description": "Contract specifications for volatility index options.",
      "properties": {
        "index_id": {
          "description": "Index identifier (e.g., \"VIX\", \"VXN\", \"VSTOXX\").",
          "type": "string"
        },
        "multiplier": {
          "description": "Contract multiplier (USD per index point).\nVIX options standard: 100 (each point = $100)",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "multiplier",
        "index_id"
      ],
      "type": "object"
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/volatility_index_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "European-style option on volatility indices (VIX, VXN, VSTOXX)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "contract_specs": {
            "index_id": "VIX",
            "multiplier": 100.0
          },
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "exercise_style": "european",
          "expiry": "2025-03-19",
          "id": "VIX-CALL-20-2025M03",
          "notional": {
            "amount": "10000",
            "currency": "USD"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "strike": 20.0,
          "vol_index_curve_id": "VIX",
          "vol_of_vol_surface_id": "VIX-VOLVOL"
        },
        "type": "volatility_index_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Volatility Index Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {}
            },
            "contract_specs": {
              "$ref": "#/$defs/VolIndexOptionSpecs",
              "default": {
                "index_id": "VIX",
                "multiplier": 100.0
              }
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            },
            "exercise_style": {
              "$ref": "#/$defs/ExerciseStyle",
              "default": "european"
            },
            "expiry": {
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              }
            },
            "settlement_date": {
              "default": null,
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "strike": {
              "format": "double",
              "type": "number"
            },
            "vol_index_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            },
            "vol_of_vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            }
          },
          "required": [
            "id",
            "notional",
            "strike",
            "option_type",
            "expiry",
            "day_count",
            "discount_curve_id",
            "vol_index_curve_id",
            "vol_of_vol_surface_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "volatility_index_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Volatility Index Option",
  "type": "object"
}
