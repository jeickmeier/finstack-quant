{
  "$defs": {
    "RealEstatePropertyType": {
      "description": "Broad property classification for reporting / tagging.",
      "oneOf": [
        {
          "const": "office",
          "description": "Office (CBD/suburban, single-tenant or multi-tenant).",
          "type": "string"
        },
        {
          "const": "multifamily",
          "description": "Multifamily / residential rental.",
          "type": "string"
        },
        {
          "const": "retail",
          "description": "Retail (strip, mall, big box, high street).",
          "type": "string"
        },
        {
          "const": "industrial",
          "description": "Industrial (warehouse, logistics, manufacturing).",
          "type": "string"
        },
        {
          "const": "hospitality",
          "description": "Hospitality (hotel, resort).",
          "type": "string"
        },
        {
          "const": "mixed_use",
          "description": "Mixed-use (multiple property types).",
          "type": "string"
        },
        {
          "const": "other",
          "description": "Other / uncategorized.",
          "type": "string"
        }
      ]
    },
    "RealEstateValuationMethod": {
      "description": "Valuation method for a real estate asset.",
      "oneOf": [
        {
          "const": "dcf",
          "description": "Discounted cashflow using an explicit NOI schedule and discount rate.",
          "type": "string"
        },
        {
          "const": "direct_cap",
          "description": "Direct capitalization using a stabilized NOI and cap rate.",
          "type": "string"
        }
      ]
    }
  },
