{
  "$defs": {
    "EquityFutureSpecs": {
      "description": "Contract specifications for equity index futures.\n\nContains exchange-specific contract parameters such as multiplier,\ntick size, and settlement method.\n\n# Examples\n\n```rust\nuse finstack_quant_valuations::instruments::equity::equity_index_future::EquityFutureSpecs;\n\n// E-mini S&P 500 specifications\nlet es_specs = EquityFutureSpecs::sp500_emini();\nassert_eq!(es_specs.multiplier, 50.0);\nassert_eq!(es_specs.tick_size, 0.25);\nassert_eq!(es_specs.tick_value, 12.50);\n```",
      "properties": {
        "multiplier": {
          "description": "Contract multiplier (USD per index point).\nE-mini S&P 500: 50.0 (each point = $50)",
          "format": "double",
          "type": "number"
        },
        "settlement_method": {
          "description": "Settlement method description.",
          "type": "string"
        },
        "tick_size": {
          "description": "Tick size in index points.\nE-mini S&P 500: 0.25 points",
          "format": "double",
          "type": "number"
        },
        "tick_value": {
          "description": "Tick value in currency units.\nE-mini S&P 500: $12.50 per tick (0.25 × 50)",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "multiplier",
        "tick_size",
        "tick_value",
        "settlement_method"
      ],
      "type": "object"
    },
    "Position": {
      "description": "Position side for futures.",
      "oneOf": [
        {
          "const": "long",
          "description": "Long position (buyer of futures contract)",
          "type": "string"
        },
        {
          "const": "short",
          "description": "Short position (seller of futures contract)",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/equity_index_future.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Equity index futures contract (E-mini S&P 500, Nasdaq-100, etc.)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "contract_specs": {
            "multiplier": 50.0,
            "settlement_method": "Cash settled to Special Opening Quotation",
            "tick_size": 0.25,
            "tick_value": 12.5
          },
          "discount_curve_id": "USD-OIS",
          "entry_price": 4500.0,
          "expiry": "2025-03-21",
          "id": "ES-2025M03",
          "last_trading_date": "2025-03-20",
          "notional": {
            "amount": "2250000",
            "currency": "USD"
          },
          "position": "long",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quoted_price": 4550.0,
          "spot_id": "SPX-SPOT",
          "underlying_ticker": "SPX"
        },
        "type": "equity_index_future"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Equity Index Future instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging"
            },
            "contract_specs": {
              "$ref": "#/$defs/EquityFutureSpecs",
              "default": {
                "multiplier": 50.0,
                "settlement_method": "Cash settled to Special Opening Quotation",
                "tick_size": 0.25,
                "tick_value": 12.5
              },
              "description": "Contract specifications."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier for present value calculations."
            },
            "discrete_dividends": {
              "description": "Optional discrete cash dividend schedule `(ex_date, amount)` for index carry.\n\nWhen non-empty, fair forward pricing uses PV spot adjustment and treats\ncontinuous dividend yield as zero to avoid double counting.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dividend yield identifier for fair value calculation."
            },
            "entry_price": {
              "description": "Entry price at trade inception (optional for new trades).",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "expiry": {
              "description": "Future expiry/settlement date.",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "last_trading_date": {
              "description": "Last trading date (typically one day before expiry).",
              "format": "date",
              "type": "string"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional exposure in settlement currency."
            },
            "position": {
              "$ref": "#/$defs/Position",
              "description": "Position side (Long or Short)."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes for tagging and selection."
            },
            "quoted_price": {
              "description": "Current quoted market price (if available, overrides fair value).",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "settlement_price": {
              "description": "Official settlement price fixed after the last trading date.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Index spot price identifier for fair value calculation."
            },
            "underlying_ticker": {
              "description": "Index ticker symbol (e.g., \"SPX\", \"NDX\", \"SX5E\").",
              "type": "string"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "notional",
            "expiry",
            "last_trading_date",
            "position",
            "discount_curve_id",
            "spot_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "equity_index_future",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Equity Index Future",
  "type": "object"
}
