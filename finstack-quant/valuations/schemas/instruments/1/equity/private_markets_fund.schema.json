{
  "$defs": {
    "CatchUpMode": {
      "description": "Catch-up mode for GP profit sharing.",
      "oneOf": [
        {
          "const": "full",
          "description": "Full catch-up: GP gets 100% until target split is reached",
          "type": "string"
        },
        {
          "const": "partial",
          "description": "Partial catch-up: GP gets configured percentage",
          "type": "string"
        }
      ]
    },
    "ClawbackSettle": {
      "description": "Clawback settlement trigger.",
      "oneOf": [
        {
          "const": "fund_end",
          "description": "Settle at fund termination",
          "type": "string"
        },
        {
          "const": "periodic",
          "description": "Settle periodically (quarterly/annually)",
          "type": "string"
        }
      ]
    },
    "ClawbackSpec": {
      "additionalProperties": false,
      "description": "Clawback specification for GP carry reconciliation.",
      "properties": {
        "enable": {
          "description": "Whether clawback is enabled",
          "type": "boolean"
        },
        "holdback_pct": {
          "description": "Optional percentage of GP carry held back until settlement",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "settle_on": {
          "$ref": "#/$defs/ClawbackSettle",
          "description": "When to settle clawback"
        }
      },
      "required": [
        "enable",
        "settle_on"
      ],
      "type": "object"
    },
    "FundEvent": {
      "additionalProperties": false,
      "description": "Single fund cash flow event.",
      "properties": {
        "amount": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
          "description": "Amount (positive for all event types, sign determined by kind)"
        },
        "date": {
          "description": "Date of the event",
          "format": "date",
          "type": "string"
        },
        "deal_id": {
          "description": "Deal identifier for American-style waterfalls",
          "type": [
            "string",
            "null"
          ]
        },
        "kind": {
          "$ref": "#/$defs/FundEventKind",
          "description": "Type of event"
        }
      },
      "required": [
        "date",
        "amount",
        "kind"
      ],
      "type": "object"
    },
    "FundEventKind": {
      "description": "Type of fund event.",
      "oneOf": [
        {
          "const": "contribution",
          "description": "Capital contribution from LP",
          "type": "string"
        },
        {
          "const": "distribution",
          "description": "Distribution to LP",
          "type": "string"
        },
        {
          "const": "proceeds",
          "description": "Sale proceeds from investment",
          "type": "string"
        }
      ]
    },
    "Hurdle": {
      "description": "Hurdle types for waterfall tiers.",
      "oneOf": [
        {
          "additionalProperties": false,
          "description": "IRR-based hurdle (annual rate)",
          "properties": {
            "irr": {
              "properties": {
                "rate": {
                  "description": "Rate.",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "rate"
              ],
              "type": "object"
            }
          },
          "required": [
            "irr"
          ],
          "type": "object"
        }
      ]
    },
    "Tranche": {
      "description": "Individual tranche in the waterfall.",
      "oneOf": [
        {
          "const": "return_of_capital",
          "description": "Return LP capital contributions before any profit sharing",
          "type": "string"
        },
        {
          "additionalProperties": false,
          "description": "Preferred return to LPs at specified IRR",
          "properties": {
            "preferred_irr": {
              "properties": {
                "irr": {
                  "description": "Irr.",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "irr"
              ],
              "type": "object"
            }
          },
          "required": [
            "preferred_irr"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Catch-up allocation to GP",
          "properties": {
            "catch_up": {
              "properties": {
                "gp_share": {
                  "description": "Gp share.",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "gp_share"
              ],
              "type": "object"
            }
          },
          "required": [
            "catch_up"
          ],
          "type": "object"
        },
        {
          "additionalProperties": false,
          "description": "Promote tier with hurdle and LP/GP split",
          "properties": {
            "promote_tier": {
              "properties": {
                "gp_share": {
                  "description": "Gp share.",
                  "format": "double",
                  "type": "number"
                },
                "hurdle": {
                  "$ref": "#/$defs/Hurdle",
                  "description": "Hurdle."
                },
                "lp_share": {
                  "description": "Lp share.",
                  "format": "double",
                  "type": "number"
                }
              },
              "required": [
                "hurdle",
                "lp_share",
                "gp_share"
              ],
              "type": "object"
            }
          },
          "required": [
            "promote_tier"
          ],
          "type": "object"
        }
      ]
    },
    "WaterfallSpec": {
      "additionalProperties": false,
      "description": "Complete waterfall specification.",
      "properties": {
        "catchup_mode": {
          "$ref": "#/$defs/CatchUpMode",
          "default": "full",
          "description": "Catch-up mode"
        },
        "clawback": {
          "anyOf": [
            {
              "$ref": "#/$defs/ClawbackSpec"
            },
            {
              "type": "null"
            }
          ],
          "default": null,
          "description": "Optional clawback specification"
        },
        "irr_basis": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
          "default": "Act365F",
          "description": "Day count basis for IRR calculations"
        },
        "style": {
          "$ref": "#/$defs/WaterfallStyle",
          "description": "Allocation style (European vs American)"
        },
        "tranches": {
          "description": "Ordered sequence of waterfall tranches",
          "items": {
            "$ref": "#/$defs/Tranche"
          },
          "type": "array"
        }
      },
      "required": [
        "style",
        "tranches"
      ],
      "type": "object"
    },
    "WaterfallStyle": {
      "description": "Waterfall allocation style.",
      "oneOf": [
        {
          "const": "european",
          "description": "European style: aggregate all events at fund level",
          "type": "string"
        },
        {
          "const": "american",
          "description": "American style: allocate per deal, then aggregate",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/private_markets_fund.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Fund with waterfall distributions and events",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "currency": "USD",
          "discount_curve_id": "USD-OIS",
          "events": [
            {
              "amount": {
                "amount": "5000000",
                "currency": "USD"
              },
              "date": "2024-01-15",
              "deal_id": null,
              "kind": "contribution"
            },
            {
              "amount": {
                "amount": "2000000",
                "currency": "USD"
              },
              "date": "2024-06-15",
              "deal_id": null,
              "kind": "contribution"
            },
            {
              "amount": {
                "amount": "4000000",
                "currency": "USD"
              },
              "date": "2026-03-01",
              "deal_id": "DEAL-1",
              "kind": "proceeds"
            },
            {
              "amount": {
                "amount": "4000000",
                "currency": "USD"
              },
              "date": "2027-01-01",
              "deal_id": null,
              "kind": "distribution"
            }
          ],
          "id": "PMF-EXAMPLE",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "waterfall_spec": {
            "catchup_mode": "full",
            "clawback": null,
            "irr_basis": "Act365F",
            "style": "european",
            "tranches": [
              "return_of_capital",
              {
                "preferred_irr": {
                  "irr": 0.08
                }
              },
              {
                "catch_up": {
                  "gp_share": 0.5
                }
              },
              {
                "promote_tier": {
                  "gp_share": 0.2,
                  "hurdle": {
                    "irr": {
                      "rate": 0.12
                    }
                  },
                  "lp_share": 0.8
                }
              }
            ]
          }
        },
        "type": "private_markets_fund"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Private Markets Fund instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging."
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Functional currency of the fund."
            },
            "discount_curve_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Discount curve identifier for NAV present-value calculations.\n\nWhen `None`, the pricer falls back to the last event date as the\nvaluation date and returns an undiscounted waterfall NAV."
            },
            "events": {
              "description": "Time-ordered list of fund events (contributions, proceeds, distributions).",
              "items": {
                "$ref": "#/$defs/FundEvent"
              },
              "type": "array"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides for scenario analysis and model configuration."
            },
            "unrealized_nav": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Unrealized net asset value attributable to the LP, stated as of the\nfund's valuation date.\n\nHolder-view residual value : the fund's present\nvalue is the PV of LP cashflows strictly after the valuation date plus\nthis NAV. When `None`, the residual value is zero — a fully realized\nfund prices to ~0."
            },
            "waterfall_spec": {
              "$ref": "#/$defs/WaterfallSpec",
              "description": "Waterfall specification defining LP/GP allocation tiers."
            }
          },
          "required": [
            "id",
            "currency",
            "waterfall_spec",
            "events"
          ],
          "type": "object"
        },
        "type": {
          "const": "private_markets_fund",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Private Markets Fund",
  "type": "object"
}
