{
  "$defs": {
    "CliquetPayoffType": {
      "description": "Cliquet payoff aggregation type.",
      "oneOf": [
        {
          "const": "Additive",
          "description": "Additive: Sum of period returns",
          "type": "string"
        },
        {
          "const": "Multiplicative",
          "description": "Multiplicative: Product of (1 + period returns) - 1",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/cliquet_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option with periodic reset caps and global cap",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "div_yield_id": "SPX-DIV",
          "expiry": "2024-12-31",
          "global_cap": 0.2,
          "global_floor": 0.0,
          "id": "CLIQ-SPX-QTR",
