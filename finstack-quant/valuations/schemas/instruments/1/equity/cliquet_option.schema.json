              "default": [],
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "payoff_type": {
              "$ref": "#/$defs/CliquetPayoffType",
