              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "default": null
            },
            "expiry": {
              "format": "date",
              "type": "string"
            },
            "global_cap": {
              "format": "double",
              "type": "number"
