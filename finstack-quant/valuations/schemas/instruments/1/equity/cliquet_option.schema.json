                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              }
            },
            "reset_dates": {
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            },
            "underlying_ticker": {
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "reset_dates",
            "expiry",
            "local_cap",
            "local_floor",
            "global_cap",
            "global_floor",
            "notional",
            "day_count",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "cliquet_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
