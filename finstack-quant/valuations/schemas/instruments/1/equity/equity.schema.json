{
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/equity.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Spot equity position in a listed stock",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "currency": "USD",
          "discount_curve_id": "USD",
          "discrete_dividends": [],
          "div_yield_id": "AAPL-DIV",
          "id": "EQUITY-AAPL",
          "price_id": "AAPL-SPOT",
          "price_quote": null,
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "shares": 100.0,
          "ticker": "AAPL"
        },
        "type": "equity"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Equity instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Currency in which the equity is quoted"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for pricing"
            },
            "discrete_dividends": {
              "default": [],
              "description": "Optional discrete cash dividends `(ex_date, amount)` for single-name forwards.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Explicit market data identifier to resolve the dividend yield"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier for the equity"
            },
            "price_id": {
              "description": "Explicit market data identifier to resolve the spot price",
              "type": [
                "string",
                "null"
              ]
            },
            "price_quote": {
              "description": "Optional price quote (if not provided, will look up from market data)",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes for scenario selection and tagging"
            },
            "shares": {
              "description": "Optional number of shares (defaults to 1 if not specified)",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "ticker": {
              "description": "Ticker symbol (e.g., \"AAPL\", \"MSFT\")",
              "type": "string"
            }
          },
          "required": [
            "id",
            "ticker",
            "currency",
            "discount_curve_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "equity",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Equity",
  "type": "object"
}
