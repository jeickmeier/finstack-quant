{
  "$defs": {
    "Position": {
      "description": "Position direction for futures and forwards.",
      "oneOf": [
        {
          "const": "long",
          "description": "Long position (buyer of the contract).",
          "type": "string"
        },
        {
          "const": "short",
          "description": "Short position (seller of the contract).",
          "type": "string"
        }
      ]
    },
    "VolIndexContractSpecs": {
      "description": "Contract specifications for volatility index futures.\n\nVIX futures have standardized specifications set by CBOE:\n- Standard multiplier: $1,000 per index point\n- Minimum tick: 0.05 index points ($50)\n- Weekly and monthly expiries available",
      "properties": {
        "index_id": {
          "description": "Index identifier (e.g., \"VIX\", \"VXN\", \"VSTOXX\").",
          "type": "string"
        },
        "multiplier": {
          "description": "Contract multiplier (USD per index point).\nVIX standard: 1000 (each point = $1,000)",
          "format": "double",
          "type": "number"
        },
        "tick_size": {
          "description": "Tick size in index points.\nVIX standard: 0.05 points",
          "format": "double",
          "type": "number"
        },
        "tick_value": {
          "description": "Tick value in currency units.\nVIX standard: $50 per tick (0.05 × 1000)",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "multiplier",
        "tick_size",
        "tick_value",
        "index_id"
      ],
      "type": "object"
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/equity/volatility_index_future.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Volatility index futures contract (VIX, VXN, VSTOXX)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "contract_specs": {
            "index_id": "VIX",
            "multiplier": 1000.0,
            "tick_size": 0.05,
            "tick_value": 50.0
          },
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-03-19",
          "id": "VIX-FUT-2025M03",
          "notional": {
            "amount": "100000",
            "currency": "USD"
          },
          "position": "long",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quoted_price": 21.5,
          "settlement_date": "2025-03-19",
          "vol_index_curve_id": "VIX"
        },
        "type": "volatility_index_future"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Volatility Index Future instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "contract_specs": {
              "$ref": "#/$defs/VolIndexContractSpecs",
              "default": {
                "index_id": "VIX",
                "multiplier": 1000.0,
                "tick_size": 0.05,
                "tick_value": 50.0
              },
              "description": "Contract specifications."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier. **Unused in PV**: the future is daily\nmargined so the mark-to-market is undiscounted, and no Dv01 is\nregistered. Retained for market-data identification/scenario plumbing."
            },
            "expiry": {
              "description": "Future expiry date. For VIX futures this is the final settlement day\nitself (the Wednesday ~30 days before the expiry of the SPX options\nused in the settlement calculation), not a date 30 days before\nsettlement.",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier."
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional exposure in currency units. PV is scaled by\n`notional.amount() / (multiplier × quoted_price)` to represent\nthe number of contracts."
            },
            "position": {
              "$ref": "#/$defs/Position",
              "description": "Position side (Long or Short)."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes for tagging and selection."
            },
            "quoted_price": {
              "description": "Quoted future price (index points, e.g., 21.50).",
              "format": "double",
              "type": "number"
            },
            "settlement_date": {
              "description": "Final settlement date — the morning Special Opening Quotation (SOQ)\nof the index is computed on this date (same day as `expiry` for VIX).",
              "format": "date",
              "type": "string"
            },
            "settlement_fixing": {
              "default": null,
              "description": "Final settlement/SOQ fixing in index points.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "vol_index_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility index forward curve identifier."
            }
          },
          "required": [
            "id",
            "notional",
            "expiry",
            "settlement_date",
            "quoted_price",
            "position",
            "discount_curve_id",
            "vol_index_curve_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "volatility_index_future",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Volatility Index Future",
  "type": "object"
}
