{
  "$defs": {
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/commodity/commodity_spread_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Spread option on the price difference between two commodity underlyings",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "correlation": 0.85,
          "currency": "USD",
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-09-15",
          "id": "WTI-RBOB-CRACK-SPREAD",
          "leg1_forward_curve_id": "RBOB-FORWARD",
          "leg1_vol_surface_id": "RBOB-VOL",
          "leg2_forward_curve_id": "WTI-FORWARD",
          "leg2_vol_surface_id": "WTI-VOL",
          "notional": 10000.0,
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "strike": 5.0
        },
        "type": "commodity_spread_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Commodity Spread Option instrument definition",
      "properties": {
        "spec": {
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging."
            },
            "correlation": {
              "description": "Correlation between the two commodity prices, in [-1, 1].",
              "format": "double",
              "type": "number"
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Settlement currency."
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "default": "Act365F",
              "description": "Day count convention for time to expiry."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value."
            },
            "expiry": {
              "description": "Option expiry date.",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "leg1_forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward/price curve ID for leg 1 (the \"long\" commodity)."
            },
            "leg1_vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for leg 1."
            },
            "leg2_forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward/price curve ID for leg 2 (the \"short\" commodity)."
            },
            "leg2_vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for leg 2."
            },
            "notional": {
              "description": "Notional quantity (number of units).",
              "format": "double",
              "type": "number"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put on the spread S1 - S2)."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (implied vol, etc.)."
            },
            "strike": {
              "description": "Spread strike price K in the payoff max(S1 - S2 - K, 0).",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "id",
            "currency",
            "option_type",
            "expiry",
            "strike",
            "notional",
            "leg1_forward_curve_id",
            "leg2_forward_curve_id",
            "leg1_vol_surface_id",
            "leg2_vol_surface_id",
            "discount_curve_id",
            "correlation"
          ],
          "type": "object"
        },
        "type": {
          "const": "commodity_spread_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Commodity Spread Option",
  "type": "object"
}
