{
  "$defs": {
    "AveragingMethod": {
      "description": "Averaging method for Asian options.",
      "oneOf": [
        {
          "const": "arithmetic",
          "description": "Arithmetic average: (1/n) Σ S_i",
          "type": "string"
        },
        {
          "const": "geometric",
          "description": "Geometric average: (Π S_i)^(1/n)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/commodity/commodity_asian_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Asian option on a commodity underlying with arithmetic or geometric averaging",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "averaging_method": "arithmetic",
          "commodity_type": "Energy",
          "currency": "USD",
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-07-02",
          "fixing_dates": [
            "2025-01-31",
            "2025-02-28",
            "2025-03-31",
            "2025-04-30",
            "2025-05-31",
            "2025-06-30"
          ],
          "forward_curve_id": "CL-FORWARD",
          "id": "WTI-ASIAN-6M",
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quantity": 1000.0,
          "realized_fixings": [],
          "strike": 75.0,
          "ticker": "CL",
          "unit": "BBL",
          "vol_surface_id": "CL-VOL"
        },
        "type": "commodity_asian_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Commodity Asian Option instrument definition",
      "properties": {
        "spec": {
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and grouping.\nAttributes for scenario selection and tagging"
            },
            "averaging_method": {
              "$ref": "#/$defs/AveragingMethod",
              "description": "Averaging method (arithmetic or geometric)."
            },
            "commodity_type": {
              "description": "Commodity type (e.g., \"Energy\", \"Metal\", \"Agricultural\")",
              "type": "string"
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency for pricing"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "default": "Act365F",
              "description": "Day count convention."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations."
            },
            "expiry": {
              "description": "Option expiry/settlement date for the payoff.",
              "format": "date",
              "type": "string"
            },
            "fixing_dates": {
              "description": "Dates on which the commodity price is observed for averaging.\n\n**Note**: These dates should be pre-adjusted for business day conventions.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward/futures price curve ID."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put)."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides."
            },
            "quantity": {
              "description": "Contract quantity in commodity units.",
              "format": "double",
              "type": "number"
            },
            "realized_fixings": {
              "default": [],
              "description": "Already observed fixings for seasoned options (ex-date, price pairs).",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "strike": {
              "description": "Strike price per unit.",
              "format": "double",
              "type": "number"
            },
            "ticker": {
              "description": "Ticker/identifier for market data lookup (e.g., \"CL\", \"GC\", \"NG\")",
              "type": "string"
            },
            "unit": {
              "description": "Unit of measurement (e.g., \"BBL\", \"OZ\", \"MT\", \"MMBTU\")",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for implied vol."
            }
          },
          "required": [
            "id",
            "commodity_type",
            "ticker",
            "unit",
            "currency",
            "strike",
            "option_type",
            "averaging_method",
            "fixing_dates",
            "quantity",
            "expiry",
            "forward_curve_id",
            "discount_curve_id",
            "vol_surface_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "commodity_asian_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Commodity Asian Option",
  "type": "object"
}
