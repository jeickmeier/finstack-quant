{
  "$defs": {
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/commodity/commodity_swaption.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option on a commodity swap with European exercise",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "bdc": "modified_following",
          "commodity_type": "Energy",
          "currency": "USD",
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-06-15",
          "fixed_price": 3.5,
          "forward_curve_id": "NG-FORWARD",
          "id": "NG-SWAPTION-2025",
          "notional": 10000.0,
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "swap_end": "2026-06-30",
          "swap_frequency": {
            "count": 1,
            "unit": "months"
          },
          "swap_start": "2025-07-01",
          "ticker": "NG",
          "unit": "MMBTU",
          "vol_surface_id": "NG-VOL"
        },
        "type": "commodity_swaption"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Commodity Swaption instrument definition",
      "properties": {
        "spec": {
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging."
            },
            "bdc": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/business_day_convention.schema.json",
              "default": "modified_following",
              "description": "Business day convention for date adjustments."
            },
            "calendar_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional calendar ID for date adjustments."
            },
            "commodity_type": {
              "description": "Commodity type (e.g., \"Energy\", \"Metal\", \"Agricultural\")",
              "type": "string"
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency for pricing"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "default": "Act365F",
              "description": "Day count convention for time to expiry."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value."
            },
            "expiry": {
              "description": "Option expiry date.",
              "format": "date",
              "type": "string"
            },
            "fixed_price": {
              "description": "Fixed price (strike) of the underlying swap.",
              "format": "double",
              "type": "number"
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward/futures curve ID for commodity price interpolation."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "notional": {
              "description": "Notional quantity per period.",
              "format": "double",
              "type": "number"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call = right to enter pay-fixed swap, put = right to enter receive-fixed swap)."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (implied vol, etc.)."
            },
            "swap_end": {
              "description": "Underlying swap end date.",
              "type": "string"
            },
            "swap_frequency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/tenor.schema.json",
              "description": "Underlying swap payment frequency."
            },
            "swap_start": {
              "description": "Underlying swap start date.",
              "type": "string"
            },
            "ticker": {
              "description": "Ticker/identifier for market data lookup (e.g., \"CL\", \"GC\", \"NG\")",
              "type": "string"
            },
            "unit": {
              "description": "Unit of measurement (e.g., \"BBL\", \"OZ\", \"MT\", \"MMBTU\")",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for implied vol."
            }
          },
          "required": [
            "id",
            "commodity_type",
            "ticker",
            "unit",
            "currency",
            "option_type",
            "expiry",
            "swap_start",
            "swap_end",
            "swap_frequency",
            "fixed_price",
            "notional",
            "forward_curve_id",
            "discount_curve_id",
            "vol_surface_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "commodity_swaption",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Commodity Swaption",
  "type": "object"
}
