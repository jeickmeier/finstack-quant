{
  "$defs": {
    "CommodityConvention": {
      "description": "Standard commodity market conventions by product type.\n\nEach variant provides market-standard defaults for settlement days,\nbusiness day convention, and calendar. Use when constructing commodity\nforwards, options, or swaps without explicitly specifying these parameters.\n\n# Market Standards Reference\n\n| Convention | Settlement | BDC | Calendar | Exchange |\n|------------|------------|-----|----------|----------|\n| WTI Crude | T+2 | Following | NYMEX | NYMEX/CME |\n| Brent Crude | T+2 | Following | ICE | ICE |\n| Natural Gas | T+2 | Following | NYMEX | NYMEX/CME |\n| Gold | T+2 | Modified Following | COMEX | CME |\n| Silver | T+2 | Modified Following | COMEX | CME |\n| Copper | T+2 | Following | LME | LME |\n| Corn/Wheat | T+2 | Following | CBOT | CME |\n| Power | T+1 | Modified Following | NERC | Various |\n\n# Sources\n\n- CME Group rulebooks\n- ICE Futures exchange rules\n- LME trading procedures",
      "oneOf": [
        {
          "const": "w_t_i_crude",
          "description": "WTI Crude Oil: T+2, Following, NYMEX calendar",
          "type": "string"
        },
        {
          "const": "brent_crude",
          "description": "Brent Crude Oil: T+2, Following, ICE calendar",
          "type": "string"
        },
        {
          "const": "natural_gas",
          "description": "Henry Hub Natural Gas: T+2, Following, NYMEX calendar",
          "type": "string"
        },
        {
          "const": "gold",
          "description": "COMEX Gold: T+2, Modified Following, COMEX calendar",
          "type": "string"
        },
        {
          "const": "silver",
          "description": "COMEX Silver: T+2, Modified Following, COMEX calendar",
          "type": "string"
        },
        {
          "const": "copper",
          "description": "LME Copper: T+2, Following, LME calendar",
          "type": "string"
        },
        {
          "const": "agricultural",
          "description": "CBOT Agricultural (Corn, Wheat, Soybeans): T+2, Following, CBOT calendar",
          "type": "string"
        },
        {
          "const": "power",
          "description": "Power/Electricity: T+1, Modified Following, NERC calendar",
          "type": "string"
        }
      ]
    },
    "Position": {
      "description": "Position direction for futures and forwards.",
      "oneOf": [
        {
          "const": "long",
          "description": "Long position (buyer of the contract).",
          "type": "string"
        },
        {
          "const": "short",
          "description": "Short position (seller of the contract).",
          "type": "string"
        }
      ]
    },
    "SettlementType": {
      "description": "Settlement type for options",
      "oneOf": [
        {
          "const": "physical",
          "description": "Physical delivery",
          "type": "string"
        },
        {
          "const": "cash",
          "description": "Cash settlement",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/commodity/commodity_forward.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Commodity forward or futures contract for physical or cash settlement",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {
            "meta": {
              "sector": "crude"
            },
            "tags": [
              "energy"
            ]
          },
          "commodity_type": "Energy",
          "contract_month": "2025M03",
          "convention": "w_t_i_crude",
          "currency": "USD",
          "discount_curve_id": "USD-OIS",
          "exchange": "NYMEX",
          "forward_curve_id": "WTI-FORWARD",
          "id": "WTI-FWD-2025M03",
          "maturity": "2025-03-15",
          "multiplier": 1.0,
          "position": "long",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quantity": 1000.0,
          "settlement": "cash",
          "ticker": "CL",
          "unit": "BBL"
        },
        "type": "commodity_forward"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Commodity Forward instrument definition",
      "properties": {
        "spec": {
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging"
            },
            "commodity_type": {
              "description": "Commodity type (e.g., \"Energy\", \"Metal\", \"Agricultural\")",
              "type": "string"
            },
            "contract_month": {
              "description": "Optional contract month (e.g., \"2025M03\" for March 2025).",
              "type": [
                "string",
                "null"
              ]
            },
            "contract_price": {
              "description": "Contract price (entry/trade price K).\n\nIf `None`, the forward is treated as **at-market** (K = F), meaning\nNPV ≈ 0 at inception (like a newly opened futures position).\n\nIf `Some(K)`, the forward is **off-market** and NPV reflects the\nmark-to-market difference: sign × (F - K) × Q × M × DF.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "convention": {
              "anyOf": [
                {
                  "$ref": "#/$defs/CommodityConvention"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional market convention for this commodity.\n\nWhen set, provides default settlement days and calendar if not\nexplicitly specified. See `CommodityConvention` for available options."
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency for pricing"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID."
            },
            "exchange": {
              "description": "Optional exchange identifier (e.g., \"NYMEX\", \"ICE\").",
              "type": [
                "string",
                "null"
              ]
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward/futures price curve ID for price interpolation.\n\nShould reference a `PriceCurve` in the `MarketContext`."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "maturity": {
              "description": "Settlement/delivery date.",
              "format": "date",
              "type": "string"
            },
            "multiplier": {
              "default": 1.0,
              "description": "Contract multiplier (typically 1.0 for OTC forwards, defaults to 1.0).",
              "format": "double",
              "type": "number"
            },
            "position": {
              "$ref": "#/$defs/Position",
              "default": "long",
              "description": "Position direction (long or short).\n\n- Long: buyer of the commodity at settlement\n- Short: seller of the commodity at settlement"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Instrument-owned pricing inputs."
            },
            "quantity": {
              "description": "Contract quantity in units.",
              "format": "double",
              "type": "number"
            },
            "quoted_price": {
              "description": "Optional quoted forward price (overrides curve lookup for F).\n\nThis is a market price override, not the contract entry price.\nUse `contract_price` for the trade entry price K.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "settlement": {
              "$ref": "#/$defs/SettlementType",
              "default": "cash",
              "description": "Settlement type (physical or cash).\n\nDefaults to cash settlement when omitted in serialized payloads."
            },
            "settlement_bdc": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/business_day_convention.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Business day convention for settlement date adjustment.\n\nDefaults to `Following` for energy commodities, `ModifiedFollowing`\nfor precious metals."
            },
            "settlement_calendar_id": {
              "description": "Calendar ID for settlement date adjustments.\n\nUsed for business day adjustment of the settlement date. If `convention`\nis set, uses the convention's calendar unless explicitly overridden.",
              "type": [
                "string",
                "null"
              ]
            },
            "settlement_lag_days": {
              "description": "Settlement lag in business days (T+N).\n\nDefaults to 2 for most commodity markets (T+2). If `convention` is set,\nuses the convention's default unless explicitly overridden here.\n\n# Market Standards\n\n| Market | Settlement |\n|--------|------------|\n| Energy (WTI, Brent, NG) | T+2 |\n| Precious metals | T+2 |\n| Base metals (LME) | T+2 |\n| Power | T+1 |",
              "format": "uint32",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "spot_id": {
              "description": "Optional spot price ID (for delta calculations).",
              "type": [
                "string",
                "null"
              ]
            },
            "ticker": {
              "description": "Ticker/identifier for market data lookup (e.g., \"CL\", \"GC\", \"NG\")",
              "type": "string"
            },
            "unit": {
              "description": "Unit of measurement (e.g., \"BBL\", \"OZ\", \"MT\", \"MMBTU\")",
              "type": "string"
            }
          },
          "required": [
            "id",
            "commodity_type",
            "ticker",
            "unit",
            "currency",
            "quantity",
            "maturity",
            "forward_curve_id",
            "discount_curve_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "commodity_forward",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Commodity Forward",
  "type": "object"
}
