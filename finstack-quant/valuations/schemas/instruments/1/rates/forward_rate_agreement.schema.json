{
  "$defs": {
    "PayReceive": {
      "description": "Direction for instrument legs (universal for IRS, CDS, variance swaps, etc.)\n\nFor interest rate swaps: Pay = pay fixed/receive floating, Receive = receive fixed/pay floating\nFor credit default swaps: Pay = buy protection (pay premium), Receive = sell protection (receive premium)\nFor variance swaps: Pay = short variance, Receive = long variance",
      "oneOf": [
        {
          "const": "pay",
          "description": "Pay the primary leg (fixed rate in IRS, protection premium in CDS, short variance)",
          "type": "string"
        },
        {
          "const": "receive",
          "description": "Receive the primary leg (fixed rate in IRS, protection premium in CDS, long variance)",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/forward_rate_agreement.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Forward contract on an interest rate (FRA)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "day_count": "Act360",
          "discount_curve_id": "USD-OIS",
          "fixed_rate": "0.045",
          "fixing_date": "2024-04-01",
          "forward_curve_id": "USD-SOFR-3M",
          "id": "FRA-3X6-USD",
          "maturity": "2024-07-03",
          "notional": {
            "amount": "10000000",
            "currency": "USD"
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "reset_lag": 2,
          "side": "receive",
          "start_date": "2024-04-03"
        },
        "type": "forward_rate_agreement"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Forward Rate Agreement instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention for interest accrual"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier"
            },
            "fixed_rate": {
              "description": "Fixed rate (decimal, e.g., 0.05 for 5%)",
              "pattern": "^-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?$",
              "type": [
                "string",
                "number"
              ]
            },
            "fixing_bdc": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/business_day_convention.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional business day convention for fixing date adjustment (default: ModifiedFollowing)"
            },
            "fixing_calendar_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional fixing calendar identifier for business day adjustment"
            },
            "fixing_date": {
              "description": "Rate fixing date. If `None`, inferred from `start_date - reset_lag` business days.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward curve identifier"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier"
            },
            "maturity": {
              "description": "Interest period end date",
              "format": "date",
              "type": "string"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "observed_fixing": {
              "description": "Optional observed fixing (locked rate) when known",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Instrument-owned pricing inputs."
            },
            "reset_lag": {
              "description": "Reset lag in business days (fixing to value date)",
              "format": "int32",
              "type": "integer"
            },
            "side": {
              "$ref": "#/$defs/PayReceive",
              "default": "pay",
              "description": "Direction of the FRA: Pay means paying the fixed rate (receiving floating),\nReceive means receiving the fixed rate (paying floating)."
            },
            "start_date": {
              "description": "Interest period start date",
              "format": "date",
              "type": "string"
            }
          },
          "required": [
            "id",
            "notional",
            "start_date",
            "maturity",
            "fixed_rate",
            "day_count",
            "reset_lag",
            "discount_curve_id",
            "forward_curve_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "forward_rate_agreement",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Forward Rate Agreement",
  "type": "object"
}
