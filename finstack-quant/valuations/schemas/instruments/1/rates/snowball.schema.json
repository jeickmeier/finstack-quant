{
  "$defs": {
    "BermudanCallProvision": {
      "additionalProperties": false,
      "description": "Bermudan call provision for callable exotics.\n\nAllows the issuer to terminate the note on specified call dates\nat a specified call price (typically par). Currently consumed by the\nCallable Range Accrual note (PRDC is not implemented, and the Snowball\npricer rejects callable provisions).\n\n# Fields\n\n- `call_dates`: Sorted ascending dates on which the issuer may call.\n- `call_price`: Fraction of notional returned at exercise (1.0 = par).\n- `lockout_periods`: Number of initial coupon periods during which\n  the call right cannot be exercised.",
      "properties": {
        "call_dates": {
          "description": "Dates on which the issuer can call (must be sorted ascending).",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "call_price": {
          "description": "Call price (fraction of notional, typically 1.0 = par).",
          "format": "double",
          "type": "number"
        },
        "lockout_periods": {
          "description": "Lockout period in number of coupon periods before first call.",
          "format": "uint",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "call_dates",
        "call_price",
        "lockout_periods"
      ],
      "type": "object"
    },
    "SnowballVariant": {
      "description": "Snowball note variant.",
      "oneOf": [
        {
          "const": "snowball",
          "description": "Path-dependent snowball: c_i = max(c_{i-1} + fixed - floating, 0).",
          "type": "string"
        },
        {
          "const": "inverse_floater",
          "description": "Inverse floater: c_i = max(fixed - leverage * floating, 0).",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/snowball.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Snowball instrument schema",
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Snowball instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes."
            },
            "callable": {
              "anyOf": [
                {
                  "$ref": "#/$defs/BermudanCallProvision"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional Bermudan call provision."
            },
            "coupon_cap": {
              "description": "Optional cap on each period coupon.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "coupon_dates": {
              "description": "Coupon payment dates (must be sorted ascending).",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "coupon_floor": {
              "description": "Floor on each period coupon (typically 0.0).",
              "format": "double",
              "type": "number"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID."
            },
            "fixed_rate": {
              "description": "Fixed rate component.",
              "format": "double",
              "type": "number"
            },
            "floating_index_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Floating rate index identifier."
            },
            "floating_tenor": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/tenor.schema.json",
              "description": "Floating rate tenor."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "initial_coupon": {
              "description": "Initial coupon for snowball (c_0); ignored for inverse floater.",
              "format": "double",
              "type": "number"
            },
            "leverage": {
              "description": "Leverage multiplier on floating rate (1.0 for snowball, variable for inverse floater).",
              "format": "double",
              "type": "number"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides.\nInstrument-owned pricing inputs."
            },
            "variant": {
              "$ref": "#/$defs/SnowballVariant",
              "description": "Snowball or inverse floater variant."
            },
            "vol_surface_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional normal-vol surface used to infer HW1F short-rate σ for stress scenarios."
            }
          },
          "required": [
            "id",
            "variant",
            "initial_coupon",
            "fixed_rate",
            "leverage",
            "coupon_floor",
            "notional",
            "coupon_dates",
            "floating_index_id",
            "floating_tenor",
            "discount_curve_id",
            "day_count",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "snowball",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Snowball",
  "type": "object"
}
