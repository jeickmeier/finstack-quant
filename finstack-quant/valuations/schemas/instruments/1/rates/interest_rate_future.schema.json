{
  "$defs": {
    "FutureContractSpecs": {
      "description": "Contract specifications for interest rate futures.\n\nEncapsulates exchange-defined contract parameters and optional convexity\nadjustment for pricing.",
      "properties": {
        "convexity_adjustment": {
          "description": "Optional pre-computed convexity adjustment (in rate terms).\n\n# Usage\n\n- `Some(0.0)`: Explicitly disable model-based adjustment (strict mode)\n- `Some(x)`: Use fixed adjustment of `x` (e.g., from broker quote)\n- `None`: Compute adjustment from volatility surface (requires `vol_surface_id`)\n\n# Market Practice\n\nFor calibration, use `Some(0.0)` and let the curve fitting process\nimplicitly absorb the convexity. For pricing with a pre-built curve,\neither:\n- Use a fixed adjustment from broker/vendor data\n- Provide a volatility surface for model-based calculation",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "delivery_months": {
          "description": "Number of delivery months (e.g., 3 for quarterly contracts)",
          "format": "uint8",
          "maximum": 255,
          "minimum": 0,
          "type": "integer"
        },
        "face_value": {
          "description": "Face value of contract (e.g., $1,000,000 for Eurodollar/SOFR futures)",
          "format": "double",
          "type": "number"
        },
        "tick_size": {
          "description": "Tick size in price points (e.g., 0.0025 = 0.25bp for SOFR futures)",
          "format": "double",
          "type": "number"
        },
        "tick_value": {
          "description": "Tick value in currency units (e.g., $6.25 for 3M SOFR)",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "face_value",
        "tick_size",
        "tick_value",
        "delivery_months"
      ],
      "type": "object"
    },
    "Position": {
      "description": "Position side for futures.",
      "oneOf": [
        {
          "const": "long",
          "description": "Long position (buyer of futures contract)",
          "type": "string"
        },
        {
          "const": "short",
          "description": "Short position (seller of futures contract)",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/interest_rate_future.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Exchange-traded interest rate future. `fixing_date`, `period_start`, and `period_end` are optional and may be derived from `expiry_date` and contract conventions.",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "contract_specs": {
            "convexity_adjustment": 0.0,
            "delivery_months": 3,
            "face_value": 1000000.0,
            "tick_size": 0.0025,
            "tick_value": 6.25
          },
          "day_count": "Act360",
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-03-17",
          "forward_curve_id": "USD-SOFR-3M",
          "id": "IRF-ED-3M-MAR25",
          "notional": {
            "amount": "1000000",
            "currency": "USD"
          },
          "position": "long",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quoted_price": 95.5,
          "vol_surface_id": null
        },
        "type": "interest_rate_future"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Interest Rate Future instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "contract_specs": {
              "$ref": "#/$defs/FutureContractSpecs",
              "description": "Contract specifications"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier"
            },
            "expiry": {
              "description": "Future expiry/delivery date",
              "format": "date",
              "type": "string"
            },
            "fixing_date": {
              "description": "Underlying rate fixing date.\n\nDefaults to `expiry` when omitted.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward curve identifier"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Exposure size expressed in currency units. PV is scaled by\n`notional.amount() / contract_specs.face_value` to support\nmultiples of the standard contract."
            },
            "period_end": {
              "description": "Rate period end date.\n\nDefaults to `period_start + contract_specs.delivery_months` months when omitted.",
              "type": [
                "string",
                "null"
              ]
            },
            "period_start": {
              "description": "Rate period start date.\n\nDefaults to 2 calendar days after fixing date when omitted.",
              "type": [
                "string",
                "null"
              ]
            },
            "position": {
              "$ref": "#/$defs/Position",
              "description": "Position side (Long or Short)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes"
            },
            "quoted_price": {
              "description": "Quoted future price (e.g., 99.25)",
              "format": "double",
              "type": "number"
            },
            "vol_surface_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional volatility surface identifier for convexity adjustment"
            }
          },
          "required": [
            "id",
            "notional",
            "expiry",
            "quoted_price",
            "day_count",
            "position",
            "contract_specs",
            "discount_curve_id",
            "forward_curve_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "interest_rate_future",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Interest Rate Future",
  "type": "object"
}
