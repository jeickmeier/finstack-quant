{
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/tarn.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Target redemption note instrument schema",
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Tarn instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection."
            },
            "coupon_dates": {
              "description": "Coupon payment dates (must be sorted ascending).",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "coupon_floor": {
              "description": "Floor on each period's coupon (typically 0.0).",
              "format": "double",
              "type": "number"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention for coupon accrual."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for PV calculations."
            },
            "fixed_rate": {
              "description": "Fixed coupon rate (the \"strike\" rate).",
              "format": "double",
              "type": "number"
            },
            "floating_index_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Floating rate index identifier."
            },
            "floating_tenor": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/tenor.schema.json",
              "description": "Floating rate tenor (e.g., \"3M\", \"6M\")."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides.\nInstrument-owned pricing inputs."
            },
            "target_coupon": {
              "description": "Target cumulative coupon level (triggers early redemption).\n\nA zero target is allowed and represents redemption at the first\nfuture coupon date without coupon accrual.",
              "format": "double",
              "type": "number"
            },
            "vol_surface_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional normal-vol surface used to infer HW1F short-rate σ for stress scenarios."
            }
          },
          "required": [
            "id",
            "fixed_rate",
            "coupon_floor",
            "target_coupon",
            "notional",
            "coupon_dates",
            "floating_tenor",
            "floating_index_id",
            "discount_curve_id",
            "day_count",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "tarn",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "TARN",
  "type": "object"
}
