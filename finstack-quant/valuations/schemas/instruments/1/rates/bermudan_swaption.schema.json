{
  "$defs": {
    "BermudanSchedule": {
      "description": "Bermudan exercise schedule specification.\n\nDefines the exercise dates and constraints for a Bermudan swaption.\nExercise dates are typically aligned with swap coupon dates.",
      "properties": {
        "exercise_dates": {
          "description": "Exercise dates (must be sorted, typically on swap coupon dates)",
          "items": {
            "type": "string"
          },
          "type": "array"
        },
        "lockout_end": {
          "description": "Lockout period end (no exercise before this date)",
          "type": [
            "string",
            "null"
          ]
        },
        "notice_days": {
          "description": "Notice period in business days before exercise",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "exercise_dates",
        "notice_days"
      ],
      "type": "object"
    },
    "BermudanType": {
      "description": "Co-terminal vs non-co-terminal Bermudan exercise.\n\nThis distinction affects pricing methodology and calibration:\n- Co-terminal: All exercise dates lead to the same swap end date\n- Non-co-terminal: Each exercise date may have a different remaining swap tenor",
      "oneOf": [
        {
          "const": "CoTerminal",
          "description": "All exercise dates lead to same swap end date (most common)",
          "type": "string"
        },
        {
          "const": "NonCoTerminal",
          "description": "Exercise dates may have different swap end dates",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "SwaptionSettlement": {
      "description": "Swaption settlement method",
      "oneOf": [
        {
          "const": "physical",
          "description": "Physical settlement (enter into underlying swap)",
          "type": "string"
        },
        {
          "const": "cash",
          "description": "Cash settlement (receive NPV of swap)",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/bermudan_swaption.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Bermudan swaption instrument schema.",
  "examples": [],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Bermudan Swaption instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and grouping\nAttributes for scenario selection and tagging"
            },
            "bermudan_schedule": {
              "$ref": "#/$defs/BermudanSchedule",
              "description": "Bermudan exercise schedule"
            },
            "bermudan_type": {
              "$ref": "#/$defs/BermudanType",
              "description": "Co-terminal or non-co-terminal exercise"
            },
            "calendar_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "default": null,
              "description": "Holiday calendar ID for schedule generation.\n\nControls business day adjustment for the underlying swap schedule.\nWhen `None`, uses weekends-only calendar. For production use, set to\nthe appropriate currency calendar (e.g., `\"nyse\"` for USD)."
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention for fixed leg"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "fixed_freq": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/tenor.schema.json",
              "description": "Fixed leg payment frequency"
            },
            "float_freq": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/tenor.schema.json",
              "description": "Floating leg payment frequency"
            },
            "forward_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Forward curve ID for floating rate projections"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount of underlying swap"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (payer = Call, receiver = Put)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "settlement": {
              "$ref": "#/$defs/SwaptionSettlement",
              "description": "Settlement method (physical or cash)"
            },
            "strike": {
              "description": "Strike (fixed rate on underlying swap)",
              "pattern": "^-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?$",
              "type": [
                "string",
                "number"
              ]
            },
            "swap_end": {
              "description": "Underlying swap end date (final payment)",
              "type": "string"
            },
            "swap_start": {
              "description": "Underlying swap start date (first accrual start)",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID for calibration"
            }
          },
          "required": [
            "id",
            "option_type",
            "notional",
            "strike",
            "swap_start",
            "swap_end",
            "fixed_freq",
            "float_freq",
            "day_count",
            "settlement",
            "discount_curve_id",
            "forward_curve_id",
            "vol_surface_id",
            "bermudan_schedule",
            "bermudan_type"
          ],
          "type": "object"
        },
        "type": {
          "const": "bermudan_swaption",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Bermudan Swaption",
  "type": "object"
}
