{
  "$defs": {
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/rates/ir_future_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option on an exchange-traded interest rate future",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "discount_curve_id": "USD-OIS",
          "expiry": "2025-06-16",
          "futures_price": 95.5,
          "id": "IRFO-SOFR-3M-CALL-9550",
          "notional": {
            "amount": "1000000",
            "currency": "USD"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "strike": 95.5,
          "tick_size": 0.0025,
          "tick_value": 6.25,
          "volatility": 0.2
        },
        "type": "ir_future_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Ir Future Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for PV calculation"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "futures_price": {
              "description": "Underlying futures price (e.g., 95.50 for a 4.50% implied rate)",
              "format": "double",
              "type": "number"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount per contract"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Call or Put"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides"
            },
            "strike": {
              "description": "Option strike price (in futures price terms, e.g., 95.00)",
              "format": "double",
              "type": "number"
            },
            "tick_size": {
              "description": "Tick size (e.g., 0.0025 for SOFR options)",
              "format": "double",
              "type": "number"
            },
            "tick_value": {
              "description": "Tick value in currency units (e.g., $6.25 for 1M SOFR, $25 for 3M)",
              "format": "double",
              "type": "number"
            },
            "volatility": {
              "description": "Lognormal (Black) volatility, annualized",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "id",
            "futures_price",
            "strike",
            "expiry",
            "option_type",
            "notional",
            "tick_size",
            "tick_value",
            "volatility",
            "discount_curve_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "ir_future_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "IR Future Option",
  "type": "object"
}
