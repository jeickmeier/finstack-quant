            "ytm_bump_decimal": null
          },
          "side": "pay",
          "start_date": "2024-01-15"
        },
        "type": "yoy_inflation_swap"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
