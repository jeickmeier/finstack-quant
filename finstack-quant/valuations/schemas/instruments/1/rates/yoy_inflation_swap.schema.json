            "notional",
            "start_date",
            "maturity",
            "fixed_rate",
            "frequency",
            "inflation_index_id",
            "discount_curve_id",
            "day_count",
            "side",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "yoy_inflation_swap",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
