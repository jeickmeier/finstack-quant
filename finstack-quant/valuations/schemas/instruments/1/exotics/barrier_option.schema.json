{
  "$defs": {
    "BarrierType": {
      "description": "Barrier type for barrier options.",
      "oneOf": [
        {
          "const": "up_and_out",
          "description": "Up-and-out: option knocked out if S >= B",
          "type": "string"
        },
        {
          "const": "up_and_in",
          "description": "Up-and-in: option activated if S >= B",
          "type": "string"
        },
        {
          "const": "down_and_out",
          "description": "Down-and-out: option knocked out if S <= B",
          "type": "string"
        },
        {
          "const": "down_and_in",
          "description": "Down-and-in: option activated if S <= B",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "RebateTiming": {
      "description": "Timing of a knock-out rebate payment.\n\nMarket-standard KO rebates pay **at hit** (the moment the barrier is\nbreached); paying at expiry is the less common variant. Knock-in rebates\nalways pay at expiry by definition (only at expiry is it known that the\noption failed to knock in), so this setting does not affect them.",
      "oneOf": [
        {
          "const": "at_hit",
          "description": "Rebate is paid at the barrier hit time (market standard for KO rebates).",
          "type": "string"
        },
        {
          "const": "at_expiry",
          "description": "Rebate is paid at option expiry.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/exotics/barrier_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option with knock-in/knock-out barrier",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "barrier": {
            "amount": "5000",
            "currency": "USD"
          },
          "barrier_type": "up_and_out",
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "div_yield_id": "SPX-DIV",
          "expiry": "2024-12-20",
          "id": "BAR-SPX-UO-CALL",
          "notional": {
            "amount": "100000",
            "currency": "USD"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "rebate": {
            "amount": "50",
            "currency": "USD"
          },
          "spot_id": "SPX-SPOT",
          "strike": 4500.0,
          "underlying_ticker": "SPX",
          "use_gobet_miri": true,
          "vol_surface_id": "SPX-VOL"
        },
        "type": "barrier_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Barrier Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "barrier": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Barrier level (price that triggers knock-in/out)"
            },
            "barrier_type": {
              "$ref": "#/$defs/BarrierType",
              "description": "Barrier type (up/down, in/out)"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dividend yield curve ID"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "monitoring_frequency": {
              "description": "Monitoring frequency for discrete barrier adjustment (years between observations).\n\nWhen set, the analytical pricer applies the Broadie-Glasserman correction\nto adjust the barrier level for discrete monitoring. Common values:\n- `1.0/252.0` — daily monitoring\n- `1.0/52.0` — weekly monitoring\n- `1.0/12.0` — monthly monitoring\n\nWhen `None`, the analytical pricer uses continuous monitoring formulas.\nNote: The MC pricer (`use_gobet_miri = true`) handles discrete monitoring\nindependently via per-step corrections.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "observed_barrier_breached": {
              "description": "Observed barrier state for expired options.\n\nHistorical barrier monitoring must be supplied explicitly for expired\noptions because terminal spot alone does not reveal whether the barrier\nwas breached intralife and then reversed.",
              "type": [
                "boolean",
                "null"
              ]
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "rebate": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional rebate amount (paid if the barrier condition is met; see\n`rebate_timing` for when a knock-out rebate pays)"
            },
            "rebate_timing": {
              "$ref": "#/$defs/RebateTiming",
              "default": "at_hit",
              "description": "Timing of the knock-out rebate payment.\n\n`at_hit` (default, market standard) pays the rebate the moment a\nknock-out barrier is breached; `at_expiry` defers payment to expiry.\nKnock-in rebates always pay at expiry (a no-hit is only known then),\nso this setting does not affect them. The analytical pricer values\nat-hit rebates via the discounted first-passage closed form; the Monte\nCarlo pricers currently approximate at-hit rebates as at-expiry."
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Spot price identifier"
            },
            "strike": {
              "description": "Strike price",
              "format": "double",
              "type": "number"
            },
            "underlying_ticker": {
              "description": "Underlying asset ticker symbol",
              "type": "string"
            },
            "use_gobet_miri": {
              "default": true,
              "description": "Whether to use Gobet-Miri discrete barrier adjustment for Monte Carlo pricing.\n\nWhen `true` (recommended), applies the Broadie-Glasserman-Kou / Gobet-Miri correction\nto account for discrete barrier monitoring. This adjusts the effective barrier by\n`exp(±0.5826 × σ × √Δt)` where Δt is the time step.\n\n# Default Value\n\n**Defaults to `true`** for both builder and serde deserialization, as this\nreflects real-world discrete monitoring (daily closes). Set to `false` only\nfor continuous monitoring benchmarks or academic comparisons.\n\n# Production Recommendation\n\nAlways use `true` for production pricing of barrier options. Continuous\nbarrier formulas systematically underestimate discrete barrier option values.",
              "type": "boolean"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "strike",
            "barrier",
            "option_type",
            "barrier_type",
            "expiry",
            "notional",
            "day_count",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "barrier_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Barrier Option",
  "type": "object"
}
