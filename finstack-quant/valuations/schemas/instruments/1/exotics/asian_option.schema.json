{
  "$defs": {
    "AveragingMethod": {
      "description": "Averaging method for Asian options.",
      "oneOf": [
        {
          "const": "arithmetic",
          "description": "Arithmetic average: (1/n) Σ S_i",
          "type": "string"
        },
        {
          "const": "geometric",
          "description": "Geometric average: (Π S_i)^(1/n)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/exotics/asian_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option with payoff based on average underlying price",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "averaging_method": "arithmetic",
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "div_yield_id": "SPX-DIV",
          "expiry": "2024-06-30",
          "fixing_dates": [
            "2024-01-31",
            "2024-02-29",
            "2024-03-31",
            "2024-04-30",
            "2024-05-31",
            "2024-06-30"
          ],
          "id": "ASIAN-SPX-ARITH-6M",
          "notional": {
            "amount": "100000",
            "currency": "USD"
          },
          "option_type": "call",
          "past_fixings": [],
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "spot_id": "SPX-SPOT",
          "strike": 4500.0,
          "underlying_ticker": "SPX",
          "vol_surface_id": "SPX-VOL"
        },
        "type": "asian_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Asian Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "averaging_method": {
              "$ref": "#/$defs/AveragingMethod",
              "description": "Averaging method (arithmetic or geometric)"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dividend yield curve ID"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "fixing_dates": {
              "description": "Dates on which underlying is observed for averaging.\n\n**Note**: These dates should be pre-adjusted for business day conventions.\nThe pricer uses these dates directly without further adjustment.\nSee struct-level documentation for business day convention guidance.",
              "items": {
                "type": "string"
              },
              "type": "array"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put)"
            },
            "past_fixings": {
              "default": [],
              "description": "Past fixings for seasoned options (date, observed price pairs).\n\nFor seasoned options where some averaging observations have already occurred,\nprovide the historical fixings here. Only fixings that match dates in\n`fixing_dates` and are on or before the valuation date are considered.",
              "items": {
                "maxItems": 2,
                "minItems": 2,
                "prefixItems": [
                  {
                    "type": "string"
                  },
                  {
                    "format": "double",
                    "type": "number"
                  }
                ],
                "type": "array"
              },
              "type": "array"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Spot price identifier"
            },
            "strike": {
              "description": "Strike price",
              "format": "double",
              "type": "number"
            },
            "underlying_ticker": {
              "description": "Underlying asset ticker symbol",
              "type": "string"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "strike",
            "option_type",
            "averaging_method",
            "expiry",
            "fixing_dates",
            "notional",
            "day_count",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "asian_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Asian Option",
  "type": "object"
}
