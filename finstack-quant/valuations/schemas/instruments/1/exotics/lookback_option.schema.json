{
  "$defs": {
    "LookbackType": {
      "description": "Lookback option type.",
      "oneOf": [
        {
          "const": "fixed_strike",
          "description": "Fixed strike lookback: payoff depends on max/min relative to fixed strike",
          "type": "string"
        },
        {
          "const": "floating_strike",
          "description": "Floating strike lookback: strike is determined by path extremum",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/exotics/lookback_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option with payoff based on the max/min of the underlying over a period",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "day_count": "Act365F",
          "discount_curve_id": "USD-OIS",
          "div_yield_id": "SPX-DIV",
          "expiry": "2024-12-20",
          "id": "LOOKBACK-SPX-FIXED-CALL",
          "lookback_type": "fixed_strike",
          "notional": {
            "amount": "100000",
            "currency": "USD"
          },
          "observed_max": null,
          "observed_min": null,
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "spot_id": "SPX-SPOT",
          "strike": 4500.0,
          "underlying_ticker": "SPX",
          "use_gobet_miri": false,
          "vol_surface_id": "SPX-VOL"
        },
        "type": "lookback_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Lookback Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve ID for present value calculations"
            },
            "div_yield_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional dividend yield curve ID"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "expiry_fixing": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Terminal underlying fixing observed at expiry.\n\nRequired when valuing after expiry so the realized payoff cannot move\nwith a later market spot snapshot. At expiry itself, the current market\nspot is treated as the terminal fixing when this field is absent."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "lookback_type": {
              "$ref": "#/$defs/LookbackType",
              "description": "Lookback type (fixed or floating strike)"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "observed_max": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Observed maximum spot price since inception (required for Floating Put / Fixed Call)"
            },
            "observed_min": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Observed minimum spot price since inception (required for Floating Call / Fixed Put)"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "spot_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Spot price identifier"
            },
            "strike": {
              "description": "Strike price (None for floating strike lookbacks)",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "underlying_ticker": {
              "description": "Underlying asset ticker symbol",
              "type": "string"
            },
            "use_gobet_miri": {
              "default": false,
              "description": "Whether to use Monte Carlo with Gobet-Miri correction for discrete monitoring.\n\nWhen `true`, `value()` dispatches to `npv_mc()` for discrete-monitoring-corrected\npricing using Monte Carlo simulation.\n\n**Defaults to `false`** (analytical continuous pricing).\nSet to `true` for production pricing of discretely-monitored lookbacks.",
              "type": "boolean"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface ID"
            }
          },
          "required": [
            "id",
            "underlying_ticker",
            "option_type",
            "lookback_type",
            "expiry",
            "notional",
            "day_count",
            "discount_curve_id",
            "spot_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "lookback_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Lookback Option",
  "type": "object"
}
