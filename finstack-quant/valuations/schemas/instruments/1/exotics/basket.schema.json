{
  "$defs": {
    "BasketConstituent": {
      "description": "Individual constituent in a basket",
      "properties": {
        "id": {
          "description": "Unique identifier for the constituent",
          "type": "string"
        },
        "reference": {
          "$ref": "#/$defs/ConstituentReference",
          "description": "Reference to the underlying asset"
        },
        "ticker": {
          "description": "Optional ticker symbol for reporting",
          "type": [
            "string",
            "null"
          ]
        },
        "units": {
          "description": "Number of units for physical replication (optional)",
          "format": "double",
          "type": [
            "number",
            "null"
          ]
        },
        "weight": {
          "description": "Weight in the basket (as a fraction, e.g., 0.05 = 5%)",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "id",
        "reference",
        "weight"
      ],
      "type": "object"
    },
    "BasketPricingConfig": {
      "description": "Configuration for basket pricing behaviour.",
      "properties": {
        "days_in_year": {
          "description": "Day basis used for fee accrual (e.g., 365.0 or 365.25). Avoid hardcoding in logic.",
          "format": "double",
          "type": "number"
        },
        "fx_policy": {
          "$ref": "#/$defs/FxConversionPolicy",
          "description": "FX policy hint for conversions when constituent currency != basket currency."
        }
      },
      "required": [
        "days_in_year",
        "fx_policy"
      ],
      "type": "object"
    },
    "ConstituentReference": {
      "type": "object"
    },
    "FxConversionPolicy": {
      "description": "Standard FX conversion strategies used to hint FX providers.\n\nThe policy tells a provider *how* the rate will be applied so it can decide\nbetween spot, forward, or averaged sources.",
      "oneOf": [
        {
          "const": "cashflow_date",
          "description": "Use spot/forward on the cashflow date.",
          "type": "string"
        },
        {
          "const": "period_end",
          "description": "Use period end date.",
          "type": "string"
        },
        {
          "const": "period_average",
          "description": "Use an average over the period.",
          "type": "string"
        },
        {
          "const": "custom",
          "description": "Custom strategy defined by the caller/provider.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/exotics/basket.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Basket of assets with expense ratio",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "constituents": [
            {
              "id": "EQ-AAPL",
              "reference": {
                "asset_type": "equity",
                "price_id": "AAPL-SPOT"
              },
              "ticker": "AAPL",
              "units": null,
              "weight": 0.6
            },
            {
              "id": "BOND-UST10",
              "reference": {
                "asset_type": "bond",
                "price_id": "UST10Y-PRICE"
              },
              "ticker": "UST10Y",
              "units": null,
              "weight": 0.4
            }
          ],
          "currency": "USD",
          "discount_curve_id": "USD-OIS",
          "expense_ratio": 0.0025,
          "id": "BASKET-60-40",
          "notional": {
            "amount": "1000000",
            "currency": "USD"
          },
          "pricing_config": {
            "days_in_year": 365.25,
            "fx_policy": "cashflow_date"
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          }
        },
        "type": "basket"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Basket instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "constituents": {
              "description": "Basket constituents (the actual holdings)",
              "items": {
                "$ref": "#/$defs/BasketConstituent"
              },
              "type": "array"
            },
            "currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency of the basket"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier for present value calculations"
            },
            "expense_ratio": {
              "description": "Total expense ratio (as decimal, e.g., 0.0025 = 0.25%)\nThis affects pricing through expense drag calculations",
              "format": "double",
              "type": "number"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Position notional used to scale basket NAV to portfolio PV."
            },
            "pricing_config": {
              "$ref": "#/$defs/BasketPricingConfig",
              "description": "Pricing configuration"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes for scenario selection and tagging"
            }
          },
          "required": [
            "id",
            "constituents",
            "expense_ratio",
            "currency",
            "notional",
            "discount_curve_id",
            "attributes",
            "pricing_config"
          ],
          "type": "object"
        },
        "type": {
          "const": "basket",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Basket",
  "type": "object"
}
