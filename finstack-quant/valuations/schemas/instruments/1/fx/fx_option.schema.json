{
  "$defs": {
    "ExerciseStyle": {
      "description": "Exercise style for options",
      "oneOf": [
        {
          "const": "european",
          "description": "European exercise (only at expiry)",
          "type": "string"
        },
        {
          "const": "american",
          "description": "American exercise (any time before/at expiry)",
          "type": "string"
        },
        {
          "const": "bermudan",
          "description": "Bermudan exercise (specific dates before expiry)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "SettlementType": {
      "description": "Settlement type for options",
      "oneOf": [
        {
          "const": "physical",
          "description": "Physical delivery",
          "type": "string"
        },
        {
          "const": "cash",
          "description": "Cash settlement",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fx/fx_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Vanilla foreign exchange option (Garman-Kohlhagen model)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "base_currency": "EUR",
          "day_count": "Act365F",
          "domestic_discount_curve_id": "USD-OIS",
          "exercise_style": "european",
          "expiry": "2024-06-21",
          "foreign_discount_curve_id": "EUR-OIS",
          "id": "FXOPT-EURUSD-CALL",
          "notional": {
            "amount": "1000000",
            "currency": "EUR"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quote_currency": "USD",
          "settlement": "cash",
          "strike": 1.12,
          "vol_surface_id": "EURUSD-VOL"
        },
        "type": "fx_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Fx Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "base_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency (foreign currency)"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "default": "Act365F",
              "description": "Day count convention"
            },
            "domestic_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Domestic currency discount curve ID"
            },
            "exercise_style": {
              "$ref": "#/$defs/ExerciseStyle",
              "default": "european",
              "description": "Exercise style (European or American)"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "foreign_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Foreign currency discount curve ID"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount in base currency"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put on base currency)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)\nInstrument-owned pricing inputs."
            },
            "quote_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Quote currency (domestic currency)"
            },
            "settlement": {
              "$ref": "#/$defs/SettlementType",
              "default": "cash",
              "description": "Settlement type (physical or cash)"
            },
            "strike": {
              "description": "Strike exchange rate (quote per base).\n\n**Note on ATM convention**: Professional FX markets define ATM as the\nDelta-Neutral Straddle (DNS) strike, not the forward rate. See module\ndocumentation for details. If constructing an \"ATM\" option, compute\nthe forward rate or DNS strike externally.",
              "format": "double",
              "type": "number"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "FX volatility surface ID"
            }
          },
          "required": [
            "id",
            "base_currency",
            "quote_currency",
            "strike",
            "option_type",
            "expiry",
            "notional",
            "domestic_discount_curve_id",
            "foreign_discount_curve_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "fx_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Option",
  "type": "object"
}
