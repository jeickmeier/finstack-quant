{
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fx/fx_forward.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "FX forward (outright forward) using covered interest rate parity pricing",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {
            "meta": {
              "pair": "EURUSD"
            },
            "tags": [
              "fx"
            ]
          },
          "base_currency": "EUR",
          "contract_rate": 1.12,
          "domestic_discount_curve_id": "USD-OIS",
          "foreign_discount_curve_id": "EUR-OIS",
          "id": "EURUSD-FWD-6M",
          "maturity": "2025-06-15",
          "notional": {
            "amount": "1000000",
            "currency": "EUR"
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quote_currency": "USD"
        },
        "type": "fx_forward"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Fx Forward instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "base_calendar_id": {
              "description": "Optional base currency calendar for business day adjustment.",
              "type": [
                "string",
                "null"
              ]
            },
            "base_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency (foreign currency, numerator of the pair)."
            },
            "contract_rate": {
              "description": "Contract forward rate (quote per base). If None, valued at-market.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "domestic_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Domestic (quote currency) discount curve ID."
            },
            "foreign_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Foreign (base currency) discount curve ID."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "maturity": {
              "description": "Maturity/settlement date.",
              "format": "date",
              "type": "string"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount in base currency."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Attributes for tagging and selection.\nInstrument-owned pricing inputs."
            },
            "quote_calendar_id": {
              "description": "Optional quote currency calendar for business day adjustment.",
              "type": [
                "string",
                "null"
              ]
            },
            "quote_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Quote currency (domestic currency, denominator of the pair, PV currency)."
            },
            "spot_rate_override": {
              "description": "Optional spot rate override (quote per base). If None, source from FxMatrix.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            }
          },
          "required": [
            "id",
            "base_currency",
            "quote_currency",
            "maturity",
            "notional",
            "domestic_discount_curve_id",
            "foreign_discount_curve_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "fx_forward",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Forward",
  "type": "object"
}
