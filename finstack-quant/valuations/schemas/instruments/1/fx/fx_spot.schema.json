{
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fx/fx_spot.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "FX spot position representing immediate currency exchange",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "base_calendar_id": null,
          "base_currency": "EUR",
          "bdc": "modified_following",
          "id": "EURUSD",
          "notional": {
            "amount": "1000000",
            "currency": "EUR"
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quote_calendar_id": null,
          "quote_currency": "USD",
          "settlement": null,
          "settlement_lag_days": 2,
          "spot_rate": 1.1
        },
        "type": "fx_spot"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Fx Spot instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and tagging"
            },
            "base_calendar_id": {
              "description": "Optional base currency calendar for joint calendar settlement adjustment.\n\nPer market convention, FX settlement uses the joint calendar of both currencies.\nA date is a good business day only if it's valid in both calendars.",
              "type": [
                "string",
                "null"
              ]
            },
            "base_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency (the currency being priced)"
            },
            "bdc": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/business_day_convention.schema.json",
              "default": "modified_following",
              "description": "Business day convention to apply when adjusting settlement (default: ModifiedFollowing)\n\nNote: Default changed from `Following` to `ModifiedFollowing` in v0.8.0 to align\nwith ISDA standard FX settlement conventions."
            },
            "discount_curve_id": {
              "anyOf": [
                {
                  "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Optional quote-currency discount curve for PV-ing the settlement\ncashflow. When absent the settlement amount is reported undiscounted\n(a 1–2 day effect for standard spot lags)."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique identifier for the FX pair"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount in base currency."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Per-instrument pricing/sensitivity override knobs.\nInstrument-owned pricing inputs."
            },
            "quote_calendar_id": {
              "description": "Optional quote currency calendar for joint calendar settlement adjustment.\n\nPer market convention, FX settlement uses the joint calendar of both currencies.\nA date is a good business day only if it's valid in both calendars.",
              "type": [
                "string",
                "null"
              ]
            },
            "quote_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Quote currency (the currency used for pricing)"
            },
            "settlement": {
              "description": "Optional settlement date (T+2 typically for spot)",
              "type": [
                "string",
                "null"
              ]
            },
            "settlement_lag_days": {
              "description": "Optional settlement lag in business days when `settlement` is not provided (default: 2)",
              "format": "int32",
              "type": [
                "integer",
                "null"
              ]
            },
            "spot_rate": {
              "description": "Optional spot rate (if not provided, will look up from market data)",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            }
          },
          "required": [
            "id",
            "base_currency",
            "quote_currency",
            "notional",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "fx_spot",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Spot",
  "type": "object"
}
