{
  "$defs": {
    "BarrierDirection": {
      "description": "Barrier direction for touch options.",
      "oneOf": [
        {
          "const": "up",
          "description": "Barrier is above current spot (spot must rise to touch).",
          "type": "string"
        },
        {
          "const": "down",
          "description": "Barrier is below current spot (spot must fall to touch).",
          "type": "string"
        }
      ]
    },
    "PayoutTiming": {
      "description": "Payout timing for touch options.",
      "oneOf": [
        {
          "const": "at_hit",
          "description": "Payout occurs immediately when barrier is hit (for one-touch).",
          "type": "string"
        },
        {
          "const": "at_expiry",
          "description": "Payout is deferred to expiry regardless of when barrier is hit.",
          "type": "string"
        }
      ]
    },
    "TouchType": {
      "description": "Touch type: one-touch (pays if barrier is hit) or no-touch (pays if not hit).",
      "oneOf": [
        {
          "const": "one_touch",
          "description": "Pays if the spot rate touches the barrier at any time before expiry.",
          "type": "string"
        },
        {
          "const": "no_touch",
          "description": "Pays if the spot rate does NOT touch the barrier before expiry.",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fx/fx_touch_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "FX touch/no-touch barrier option with configurable barrier direction and payout timing",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "barrier_direction": "down",
          "barrier_level": 1.05,
          "base_currency": "EUR",
          "day_count": "Act365F",
          "domestic_discount_curve_id": "USD-OIS",
          "expiry": "2024-06-21",
          "foreign_discount_curve_id": "EUR-OIS",
          "id": "FXTOUCH-EURUSD-OT",
          "payout_amount": {
            "amount": "1000000",
            "currency": "USD"
          },
          "payout_timing": "at_expiry",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quote_currency": "USD",
          "touch_type": "one_touch",
          "vol_surface_id": "EURUSD-VOL"
        },
        "type": "fx_touch_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Fx Touch Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "barrier_direction": {
              "$ref": "#/$defs/BarrierDirection",
              "description": "Barrier direction (up or down)"
            },
            "barrier_level": {
              "description": "Barrier level (exchange rate that triggers the touch)",
              "format": "double",
              "type": "number"
            },
            "base_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency (foreign currency)"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "domestic_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Domestic currency discount curve ID"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "foreign_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Foreign currency discount curve ID"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "observed_touch": {
              "description": "Observed barrier event state for expired valuations.\n\n`Some(true)` means the barrier was touched during the option life,\n`Some(false)` means it was observed not to have touched, and `None`\nmeans the historical touch state is unavailable.\n\nThis is only required once the option has expired. Without it, a\ntouched-and-reverted path cannot be distinguished from an untouched path\nusing the terminal spot alone.",
              "type": [
                "boolean",
                "null"
              ]
            },
            "payout_amount": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Fixed payout amount"
            },
            "payout_timing": {
              "$ref": "#/$defs/PayoutTiming",
              "description": "Payout timing (at hit or at expiry)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "quote_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Quote currency (domestic currency)"
            },
            "touch_type": {
              "$ref": "#/$defs/TouchType",
              "description": "Touch type (one-touch or no-touch)"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "FX volatility surface ID"
            }
          },
          "required": [
            "id",
            "base_currency",
            "quote_currency",
            "barrier_level",
            "touch_type",
            "barrier_direction",
            "payout_amount",
            "payout_timing",
            "expiry",
            "day_count",
            "domestic_discount_curve_id",
            "foreign_discount_curve_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "fx_touch_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Touch Option",
  "type": "object"
}
