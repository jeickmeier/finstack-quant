{
  "$defs": {
    "DigitalPayoutType": {
      "description": "Payout type for digital (binary) options.",
      "oneOf": [
        {
          "const": "cash_or_nothing",
          "description": "Pays a fixed cash amount in the payout currency if ITM at expiry.",
          "type": "string"
        },
        {
          "const": "asset_or_nothing",
          "description": "Pays one unit of the foreign (base) currency if ITM at expiry.",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fx/fx_digital_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "FX digital (binary) option with cash-or-nothing or asset-or-nothing payout",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "base_currency": "EUR",
          "day_count": "Act365F",
          "domestic_discount_curve_id": "USD-OIS",
          "expiry": "2024-06-21",
          "foreign_discount_curve_id": "EUR-OIS",
          "id": "FXDIG-EURUSD-CALL",
          "notional": {
            "amount": "1000000",
            "currency": "EUR"
          },
          "option_type": "call",
          "payout_amount": {
            "amount": "1000000",
            "currency": "USD"
          },
          "payout_type": "cash_or_nothing",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "quote_currency": "USD",
          "strike": 1.12,
          "vol_surface_id": "EURUSD-VOL"
        },
        "type": "fx_digital_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Fx Digital Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "description": "Attributes for scenario selection and grouping"
            },
            "base_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Base currency (foreign currency)"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention"
            },
            "domestic_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Domestic currency discount curve ID"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "foreign_discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Foreign currency discount curve ID"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount in base currency"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (call or put on base currency)"
            },
            "payout_amount": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Fixed payout amount (used for cash-or-nothing; for asset-or-nothing this\nis the notional of foreign currency delivered)"
            },
            "payout_type": {
              "$ref": "#/$defs/DigitalPayoutType",
              "description": "Payout type (cash-or-nothing or asset-or-nothing)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (manual price, yield, spread)"
            },
            "quote_currency": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/currency.schema.json",
              "description": "Quote currency (domestic currency)"
            },
            "strike": {
              "description": "Strike exchange rate (quote per base)",
              "format": "double",
              "type": "number"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "FX volatility surface ID"
            }
          },
          "required": [
            "id",
            "base_currency",
            "quote_currency",
            "strike",
            "option_type",
            "payout_type",
            "payout_amount",
            "expiry",
            "day_count",
            "notional",
            "domestic_discount_curve_id",
            "foreign_discount_curve_id",
            "vol_surface_id",
            "attributes"
          ],
          "type": "object"
        },
        "type": {
          "const": "fx_digital_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "FX Digital Option",
  "type": "object"
}
