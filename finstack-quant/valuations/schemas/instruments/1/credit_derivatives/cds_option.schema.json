{
  "$defs": {
    "CDSConvention": {
      "description": "ISDA CDS conventions",
      "oneOf": [
        {
          "const": "isda_na",
          "description": "Standard North American convention (quarterly, Act/360)",
          "type": "string"
        },
        {
          "const": "isda_eu",
          "description": "Standard European convention (quarterly, Act/360)",
          "type": "string"
        },
        {
          "const": "isda_as",
          "description": "Standard Asian convention (quarterly, Act/365)",
          "type": "string"
        },
        {
          "const": "custom",
          "description": "Custom convention",
          "type": "string"
        }
      ]
    },
    "ExerciseStyle": {
      "description": "Exercise style for options",
      "oneOf": [
        {
          "const": "european",
          "description": "European exercise (only at expiry)",
          "type": "string"
        },
        {
          "const": "american",
          "description": "American exercise (any time before/at expiry)",
          "type": "string"
        },
        {
          "const": "bermudan",
          "description": "Bermudan exercise (specific dates before expiry)",
          "type": "string"
        }
      ]
    },
    "OptionType": {
      "description": "Option type for pricing",
      "oneOf": [
        {
          "const": "call",
          "description": "Call option",
          "type": "string"
        },
        {
          "const": "put",
          "description": "Put option",
          "type": "string"
        }
      ]
    },
    "ProtectionStartConvention": {
      "description": "Accrual-start convention for the synthetic underlying CDS used by CDSO.",
      "oneOf": [
        {
          "const": "spot",
          "description": "Spot-protection CDS: standard prior CDS roll relative to valuation date.",
          "type": "string"
        },
        {
          "const": "forward",
          "description": "Forward-protection CDS: accrual starts at option expiry.",
          "type": "string"
        }
      ]
    },
    "SettlementType": {
      "description": "Settlement type for options",
      "oneOf": [
        {
          "const": "physical",
          "description": "Physical delivery",
          "type": "string"
        },
        {
          "const": "cash",
          "description": "Cash settlement",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/credit_derivatives/cds_option.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Option on a CDS spread. Current support is limited to European, cash-settled CDS options.",
  "examples": [
    {
      "instrument": {
        "spec": {
          "attributes": {},
          "cds_maturity": "2030-06-20",
          "credit_curve_id": "CORP-HAZARD",
          "discount_curve_id": "USD-OIS",
          "exercise_style": "european",
          "expiry": "2025-06-20",
          "id": "CDSOPT-CALL-CORP-5Y",
          "index_factor": null,
          "knockout": false,
          "notional": {
            "amount": "10000000",
            "currency": "USD"
          },
          "option_type": "call",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_act360_include_last_day": false,
            "cds_aod_half_day_bias": false,
            "credit_spread_bump_bp": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "oas_price_basis": "settlement_dirty",
            "oas_quote_compounding": "continuous",
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "protection_start_convention": "spot",
          "recovery_rate": 0.4,
          "settlement": "cash",
          "strike": "0.01",
          "underlying_cds_coupon": null,
          "underlying_convention": "isda_na",
          "underlying_is_index": false,
          "vol_surface_id": "CDSOPT-VOL"
        },
        "type": "cds_option"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Cds Option instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Additional attributes"
            },
            "cash_settlement_date": {
              "description": "Cash premium settlement date for Black time-to-expiry, when the screen\nquotes option time from premium settlement rather than valuation date.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "cds_maturity": {
              "description": "Underlying CDS maturity date",
              "format": "date",
              "type": "string"
            },
            "credit_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Credit curve identifier"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier"
            },
            "exercise_settlement_date": {
              "description": "Exercise settlement date for Black time-to-expiry, when distinct from\nthe legal option expiration date.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "exercise_style": {
              "$ref": "#/$defs/ExerciseStyle",
              "description": "Exercise style"
            },
            "expiry": {
              "description": "Option expiry date",
              "format": "date",
              "type": "string"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier"
            },
            "index_factor": {
              "description": "Optional index factor scaling for the index underlying.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "knockout": {
              "default": false,
              "description": "Whether the option knocks out if the underlying defaults before\nexercise. This is contract-specific; new instruments default to\nno-knockout and legacy single-name books can opt in explicitly.",
              "type": "boolean"
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Notional amount"
            },
            "option_type": {
              "$ref": "#/$defs/OptionType",
              "description": "Option type (Call = right to buy protection, Put = right to sell protection)"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (including implied volatility)"
            },
            "protection_start_convention": {
              "$ref": "#/$defs/ProtectionStartConvention",
              "default": "spot",
              "description": "Convention used to select the synthetic underlying CDS accrual start\nwhen `underlying_effective_date` is not explicitly supplied."
            },
            "realized_index_loss": {
              "description": "Realized cumulative index loss from option inception to valuation\ndate, expressed per unit of original index notional.\n\nBloomberg CDSO treats index options as no-knockout. Settled losses\nafter option inception are therefore deterministic payoff adjustments\nat exercise (DOCS 2055833 Eq. 2.5 and DOCS 2151513). Single-name\noptions knock out instead and must leave this unset.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "recovery_rate": {
              "description": "Recovery rate assumption",
              "format": "double",
              "type": "number"
            },
            "settlement": {
              "$ref": "#/$defs/SettlementType",
              "description": "Settlement type"
            },
            "strike": {
              "description": "Strike spread as a decimal rate (e.g., 0.01 = 100bp)",
              "pattern": "^-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?$",
              "type": [
                "string",
                "number"
              ]
            },
            "underlying_cds_coupon": {
              "default": null,
              "description": "Contractual coupon `c` of the underlying CDS, expressed as a decimal\nrate (e.g., 0.01 for the 100 bp standard CDX coupon, 0.05 for the\n500 bp standard CDX.HY coupon). When `None`, the synthetic underlying\nCDS uses `strike` as its running coupon — the appropriate single-name\nSNAC default where the trade is struck at the par spread. For CDS\nindex options where the index has a fixed standard coupon different\nfrom the option strike, set this explicitly so the strike-adjustment\nterm `H(K) = ξN(c − K)A(K)` (DOCS 2055833 Eq. 2.4) is populated.",
              "pattern": "^-?\\d+(\\.\\d+)?([eE][+-]?\\d+)?$",
              "type": [
                "string",
                "number",
                "null"
              ]
            },
            "underlying_convention": {
              "$ref": "#/$defs/CDSConvention",
              "default": "isda_na",
              "description": "Convention used by the underlying CDS contract.\n\nThis controls the CDS schedule, settlement lag, business day convention,\nand other market-standard mechanics used when deriving forward spread and\nrisky annuity for the option's underlying."
            },
            "underlying_effective_date": {
              "description": "Underlying CDS accrual-effective date used for forward spread and risky\nannuity. Bloomberg CDSO can quote a standard CDS effective date before\noption expiry; in that case premium accrues from this date while\nprotection starts at expiry.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "underlying_is_index": {
              "default": false,
              "description": "If true, the underlying is a CDS index; else single-name CDS.\n\nThe Bloomberg CDSO model treats the two cases differently in the\nno-knockout calibration `F_0 = E[V_te]` (DOCS 2055833 §1.2): index\noptions trade no-knockout and the calibration target includes the\n`(1−R)·(1−q_te)` FEP-equivalent contribution; single-name options\nknock out on default and skip it.",
              "type": "boolean"
            },
            "vol_surface_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Volatility surface identifier"
            }
          },
          "required": [
            "id",
            "strike",
            "option_type",
            "exercise_style",
            "expiry",
            "cds_maturity",
            "notional",
            "settlement",
            "recovery_rate",
            "discount_curve_id",
            "credit_curve_id",
            "vol_surface_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "cds_option",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "CDS Option",
  "type": "object"
}
