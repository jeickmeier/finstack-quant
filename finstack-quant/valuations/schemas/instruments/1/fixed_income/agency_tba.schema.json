{
  "$defs": {
    "AgencyProgram": {
      "description": "Agency program enumeration.\n\nIdentifies the government-sponsored enterprise (GSE) or government agency\nthat guarantees the mortgage-backed security.\n\n# GNMA Programs\n\nGinnie Mae has two distinct programs with different payment delay conventions:\n- **GNMA I**: Single-issuer pools with a 14-day stated delay. Payments on the 15th.\n- **GNMA II**: Multi-issuer pools with a 50-day stated delay. Payments on the 20th.\n\nUse `GnmaI` or `GnmaII` to select the appropriate convention. The legacy `Gnma`\nvariant maps to GNMA II (the larger and more actively traded program).",
      "oneOf": [
        {
          "const": "FNMA",
          "description": "Fannie Mae (Federal National Mortgage Association)",
          "type": "string"
        },
        {
          "const": "FHLMC",
          "description": "Freddie Mac (Federal Home Loan Mortgage Corporation)",
          "type": "string"
        },
        {
          "const": "GNMA",
          "description": "Ginnie Mae II (Government National Mortgage Association) - multi-issuer pools.\n\nThis is the legacy variant; equivalent to `GnmaII`. Use `GnmaI` or `GnmaII`\nfor explicit program selection.",
          "type": "string"
        },
        {
          "const": "GNMA_I",
          "description": "Ginnie Mae I - single-issuer pools with 14-day stated delay.\n\nGNMA I securities pay on the 15th of the month following the accrual\nperiod, resulting in a 14-day stated delay from month-end.",
          "type": "string"
        },
        {
          "const": "GNMA_I_I",
          "description": "Ginnie Mae II - multi-issuer pools with 50-day stated delay.\n\nGNMA II securities pay on the 20th of the month following the accrual\nperiod, resulting in a ~50-day stated delay from accrual start. This is\nthe larger and more actively traded GNMA program.",
          "type": "string"
        }
      ]
    },
    "SifmaSettlementClass": {
      "description": "SIFMA MBS settlement class.\n\nSIFMA publishes distinct settlement dates for four classes of agency MBS.\nThe class determines which specific settlement date applies within a given\nmonth. See <https://www.sifma.org/resources/general/mbs-notification-and-settlement-dates/>.",
      "oneOf": [
        {
          "const": "a",
          "description": "Class A: GNMA single-family 30-year.",
          "type": "string"
        },
        {
          "const": "b",
          "description": "Class B: Conventional 30-year (FNMA/FHLMC UMBS). Most common for dollar rolls.",
          "type": "string"
        },
        {
          "const": "c",
          "description": "Class C: GNMA multi-family, ARMs, and other GNMA products.",
          "type": "string"
        },
        {
          "const": "d",
          "description": "Class D: Conventional 15-year and 20-year (FNMA/FHLMC).",
          "type": "string"
        }
      ]
    },
    "TbaTerm": {
      "description": "TBA term enumeration (original loan term).",
      "oneOf": [
        {
          "const": "fifteen_year",
          "description": "15-year original term",
          "type": "string"
        },
        {
          "const": "twenty_year",
          "description": "20-year original term",
          "type": "string"
        },
        {
          "const": "thirty_year",
          "description": "30-year original term",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fixed_income/agency_tba.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Agency TBA (To-Be-Announced) forward trade on agency MBS",
  "examples": [
    {
      "instrument": {
        "spec": {
          "agency": "FNMA",
          "attributes": {
            "meta": {
              "program": "fnma"
            },
            "tags": [
              "agency",
              "tba"
            ]
          },
          "coupon": 0.04,
          "discount_curve_id": "USD-OIS",
          "id": "FN30-4.0-202703",
          "notional": {
            "amount": "10000000",
            "currency": "USD"
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "settlement_month": 3,
          "settlement_year": 2027,
          "term": "thirty_year",
          "trade_price": 98.5
        },
        "type": "agency_tba"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Agency Tba instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "agency": {
              "$ref": "#/$defs/AgencyProgram",
              "description": "Agency program (FNMA, FHLMC, GNMA)."
            },
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for tagging and selection.\nAttributes for scenario selection and tagging"
            },
            "coupon": {
              "description": "Pass-through coupon rate (e.g., 0.04 for 4%).",
              "format": "double",
              "type": "number"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "notional": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Trade notional (par amount)."
            },
            "pool_factor": {
              "description": "Expected pool factor for valuation.\nDefaults to 1.0 (newly issued) if not specified.",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides."
            },
            "settlement_class": {
              "anyOf": [
                {
                  "$ref": "#/$defs/SifmaSettlementClass"
                },
                {
                  "type": "null"
                }
              ],
              "description": "SIFMA settlement class override.\n\nWhen `None`, inferred from agency + term using\n[`SifmaSettlementClass::from_agency_term`]."
            },
            "settlement_month": {
              "description": "Settlement month (1-12).",
              "format": "uint8",
              "maximum": 255,
              "minimum": 0,
              "type": "integer"
            },
            "settlement_year": {
              "description": "Settlement year.",
              "format": "int32",
              "type": "integer"
            },
            "term": {
              "$ref": "#/$defs/TbaTerm",
              "description": "Original loan term."
            },
            "trade_date": {
              "description": "Trade date.",
              "format": "date",
              "type": [
                "string",
                "null"
              ]
            },
            "trade_price": {
              "description": "Trade price (percentage of par, e.g., 98.5).",
              "format": "double",
              "type": "number"
            }
          },
          "required": [
            "id",
            "agency",
            "coupon",
            "term",
            "settlement_year",
            "settlement_month",
            "notional",
            "trade_price",
            "discount_curve_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "agency_tba",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Agency TBA",
  "type": "object"
}
