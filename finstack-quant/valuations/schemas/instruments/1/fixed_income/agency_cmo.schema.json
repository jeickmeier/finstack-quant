  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Agency Cmo instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "agency": {
              "$ref": "#/$defs/AgencyProgram",
              "description": "Agency program"
            },
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for tagging and selection.\nAttributes for scenario selection and tagging"
            },
            "collateral": {
              "anyOf": [
                {
                  "$ref": "#/$defs/AgencyMbsPassthrough"
                },
                {
                  "type": "null"
                }
              ],
              "description": "Collateral pool (optional - for detailed cashflow projection)"
            },
            "collateral_wac": {
              "description": "Collateral WAC (if no explicit collateral)",
              "format": "double",
              "type": [
                "number",
                "null"
              ]
            },
            "collateral_wam": {
              "description": "Collateral WAM (if no explicit collateral)",
              "format": "uint32",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "deal_name": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Deal name (e.g., \"FNR 2024-1\")"
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier."
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "issue_date": {
              "description": "Issue date",
              "format": "date",
              "type": "string"
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
