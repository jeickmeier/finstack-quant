{
  "$defs": {
    "AgencyMbsPassthrough": {
      "additionalProperties": false,
      "description": "Agency MBS passthrough instrument (pool or specified pool).\n\nRepresents an agency mortgage-backed security where principal and interest\npayments from the underlying mortgage pool are passed through to investors,\nnet of servicing and guarantee fees.\n\n# Cashflow Sign Convention\n\nAll cashflows are from the holder's (investor's) perspective:\n- Principal and interest received are positive\n- The initial purchase price is handled at trade level\n\n# Payment Delay\n\nAgency MBS have standardized payment delays measured from the **start**\nof the accrual period (first day of the month) to the payment date:\n- FNMA / FHLMC (UMBS): ~55 days → payment on the 25th of M+1\n- GNMA I: ~14 days → payment on the 15th of M\n- GNMA II: ~50 days → payment on the 20th of M+1\n\n# Examples\n\n```rust\nuse finstack_quant_valuations::instruments::fixed_income::mbs_passthrough::{\n    AgencyMbsPassthrough, AgencyProgram, PoolType,\n};\nuse finstack_quant_cashflows::builder::specs::PrepaymentModelSpec;\nuse finstack_quant_core::currency::Currency;\nuse finstack_quant_core::money::Money;\nuse finstack_quant_core::dates::Date;\nuse finstack_quant_core::types::{CurveId, InstrumentId};\nuse time::Month;\n\nlet mbs = AgencyMbsPassthrough::builder()\n    .id(InstrumentId::new(\"FN-MA1234\"))\n    .pool_id(\"MA1234\".into())\n    .agency(AgencyProgram::Fnma)\n    .pool_type(PoolType::Generic)\n    .original_face(Money::new(1_000_000.0, Currency::USD))\n    .current_face(Money::new(950_000.0, Currency::USD))\n    .current_factor(0.95)\n    .wac(0.045)\n    .pass_through_rate(0.04)\n    .servicing_fee_rate(0.0025)\n    .guarantee_fee_rate(0.0025)\n    .wam(348)\n    .issue_date(Date::from_calendar_date(2022, Month::January, 1).unwrap())\n    .maturity(Date::from_calendar_date(2052, Month::January, 1).unwrap())\n    .prepayment_model(PrepaymentModelSpec::psa(1.0))\n    .discount_curve_id(CurveId::new(\"USD-OIS\"))\n    .day_count(finstack_quant_core::dates::DayCount::Thirty360)\n    .build()\n    .expect(\"Valid MBS\");\n```",
      "properties": {
        "agency": {
          "$ref": "#/$defs/AgencyProgram",
          "description": "Agency program (FNMA, FHLMC, GNMA)."
        },
        "attributes": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
          "default": {},
          "description": "Attributes for scenario selection and tagging.\nAttributes for scenario selection and tagging"
        },
        "current_face": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
          "description": "Current face amount (remaining principal balance)."
        },
        "current_factor": {
          "description": "Current pool factor (current_face / original_face).",
          "format": "double",
          "type": "number"
        },
        "day_count": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
          "description": "Day count convention for accrual."
        },
        "discount_curve_id": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
          "description": "Discount curve identifier for pricing."
        },
        "guarantee_fee_rate": {
          "default": 0.0,
          "description": "Guarantee fee rate (annual, as decimal e.g., 0.0025 for 25 bps).\n\nDefaults to `0.0` when omitted.",
          "format": "double",
          "type": "number"
        },
        "id": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
          "description": "Unique instrument identifier."
        },
        "issue_date": {
          "description": "Issue date of the pool.",
          "format": "date",
          "type": "string"
        },
        "maturity": {
          "description": "Legal maturity date.",
          "format": "date",
          "type": "string"
        },
        "original_face": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
          "description": "Original face amount (initial principal balance)."
        },
        "pass_through_rate": {
          "description": "Pass-through rate (net coupon to investor).",
          "format": "double",
          "type": "number"
        },
        "payment_lag_days": {
          "description": "Optional custom payment delay (overrides agency default).",
          "format": "uint32",
          "minimum": 0,
          "type": [
            "integer",
            "null"
          ]
        },
        "pool_id": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
          "description": "Pool identifier (CUSIP or internal pool ID)."
        },
        "pool_type": {
          "$ref": "#/$defs/PoolType",
          "default": "generic",
          "description": "Pool type (generic or specified)."
        },
        "prepayment_model": {
          "$ref": "https://finstack_quant.dev/schemas/cashflow/1/prepayment_model_spec.schema.json",
          "description": "Prepayment model specification."
        },
        "pricing_overrides": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
          "default": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_act360_include_last_day": false,
            "cds_aod_half_day_bias": false,
            "credit_spread_bump_bp": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "oas_price_basis": "settlement_dirty",
            "oas_quote_compounding": "continuous",
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "description": "Pricing overrides (including quoted price for OAS)."
        },
        "servicing_fee_rate": {
          "default": 0.0,
          "description": "Servicing fee rate (annual, as decimal e.g., 0.0025 for 25 bps).\n\nDefaults to `0.0` when omitted.",
          "format": "double",
          "type": "number"
        },
        "wac": {
          "description": "Weighted average coupon (gross rate on underlying mortgages).",
          "format": "double",
          "type": "number"
        },
        "wam": {
          "description": "Remaining weighted average maturity in months as of the valuation\ndate (current WAM, not the original term). Pool age (WALA) for\nseasoning ramps is derived separately from `issue_date`.",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        }
      },
      "required": [
        "id",
        "pool_id",
        "agency",
        "original_face",
        "current_face",
        "current_factor",
        "wac",
        "pass_through_rate",
        "wam",
        "issue_date",
        "maturity",
        "prepayment_model",
        "discount_curve_id",
        "day_count"
      ],
      "type": "object"
    },
    "AgencyProgram": {
      "description": "Agency program enumeration.\n\nIdentifies the government-sponsored enterprise (GSE) or government agency\nthat guarantees the mortgage-backed security.\n\n# GNMA Programs\n\nGinnie Mae has two distinct programs with different payment delay conventions:\n- **GNMA I**: Single-issuer pools with a 14-day stated delay. Payments on the 15th.\n- **GNMA II**: Multi-issuer pools with a 50-day stated delay. Payments on the 20th.\n\nUse `GnmaI` or `GnmaII` to select the appropriate convention. The legacy `Gnma`\nvariant maps to GNMA II (the larger and more actively traded program).",
      "oneOf": [
        {
          "const": "FNMA",
          "description": "Fannie Mae (Federal National Mortgage Association)",
          "type": "string"
        },
        {
          "const": "FHLMC",
          "description": "Freddie Mac (Federal Home Loan Mortgage Corporation)",
          "type": "string"
        },
        {
          "const": "GNMA",
          "description": "Ginnie Mae II (Government National Mortgage Association) - multi-issuer pools.\n\nThis is the legacy variant; equivalent to `GnmaII`. Use `GnmaI` or `GnmaII`\nfor explicit program selection.",
          "type": "string"
        },
        {
          "const": "GNMA_I",
          "description": "Ginnie Mae I - single-issuer pools with 14-day stated delay.\n\nGNMA I securities pay on the 15th of the month following the accrual\nperiod, resulting in a 14-day stated delay from month-end.",
          "type": "string"
        },
        {
          "const": "GNMA_I_I",
          "description": "Ginnie Mae II - multi-issuer pools with 50-day stated delay.\n\nGNMA II securities pay on the 20th of the month following the accrual\nperiod, resulting in a ~50-day stated delay from accrual start. This is\nthe larger and more actively traded GNMA program.",
          "type": "string"
        }
      ]
    },
    "CmoTranche": {
      "description": "CMO tranche definition.",
      "properties": {
        "coupon": {
          "description": "Coupon rate (0.0 for PO)",
          "format": "double",
          "type": "number"
        },
        "current_face": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
          "description": "Current face amount"
        },
        "id": {
          "description": "Tranche identifier (e.g., \"A\", \"B\", \"IO\")",
          "type": "string"
        },
        "original_face": {
          "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
          "description": "Original face amount"
        },
        "pac_collar": {
          "anyOf": [
            {
              "$ref": "#/$defs/PacCollar"
            },
            {
              "type": "null"
            }
          ],
          "description": "PAC collar (if PAC tranche)"
        },
        "priority": {
          "description": "Payment priority (1 = highest for sequential)",
          "format": "uint32",
          "minimum": 0,
          "type": "integer"
        },
        "tranche_type": {
          "$ref": "#/$defs/CmoTrancheType",
          "description": "Tranche type"
        }
      },
      "required": [
        "id",
        "tranche_type",
        "original_face",
        "current_face",
        "coupon",
        "priority"
      ],
      "type": "object"
    },
    "CmoTrancheType": {
      "description": "CMO tranche type enumeration.",
      "oneOf": [
        {
          "const": "sequential",
          "description": "Sequential pay - receives principal in order",
          "type": "string"
        },
        {
          "const": "pac",
          "description": "PAC (Planned Amortization Class) - protected by support",
          "type": "string"
        },
        {
          "const": "support",
          "description": "Support/Companion - absorbs prepayment variability",
          "type": "string"
        },
        {
          "const": "interest_only",
          "description": "Interest-Only strip",
          "type": "string"
        },
        {
          "const": "principal_only",
          "description": "Principal-Only strip",
          "type": "string"
        }
      ]
    },
    "CmoWaterfall": {
      "description": "CMO waterfall configuration.",
      "properties": {
        "pro_rata_same_priority": {
          "description": "Whether to use pro-rata allocation within same priority",
          "type": "boolean"
        },
        "tranches": {
          "description": "Tranches in the deal (ordered by priority for sequential)",
          "items": {
            "$ref": "#/$defs/CmoTranche"
          },
          "type": "array"
        }
      },
      "required": [
        "tranches",
        "pro_rata_same_priority"
      ],
      "type": "object"
    },
    "PacCollar": {
      "description": "PAC collar boundaries.",
      "properties": {
        "lower_psa": {
          "description": "Lower PSA bound",
          "format": "double",
          "type": "number"
        },
        "upper_psa": {
          "description": "Upper PSA bound",
          "format": "double",
          "type": "number"
        }
      },
      "required": [
        "lower_psa",
        "upper_psa"
      ],
      "type": "object"
    },
    "PoolType": {
      "description": "Pool type classification.\n\nDistinguishes between generic (TBA-eligible) pools and specified pools\nwith known characteristics.",
      "oneOf": [
        {
          "const": "generic",
          "description": "Generic pool (TBA-eligible, standard assumptions)",
          "type": "string"
        },
        {
          "const": "specified",
          "description": "Specified pool with known loan-level characteristics",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fixed_income/agency_cmo.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Agency CMO (Collateralized Mortgage Obligation) tranche",
  "examples": [
    {
      "instrument": {
        "spec": {
          "agency": "FNMA",
          "attributes": {
            "meta": {
              "deal": "fnr-2024-1"
            },
            "tags": [
              "agency",
              "cmo"
            ]
          },
          "collateral_wac": 0.045,
          "collateral_wam": 360,
          "deal_name": "FNR 2024-1",
          "discount_curve_id": "USD-OIS",
          "id": "FNR-2024-1-A",
          "issue_date": "2024-01-01",
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
