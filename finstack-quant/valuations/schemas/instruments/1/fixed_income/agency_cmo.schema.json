                },
                "id": "B",
                "original_face": {
                  "amount": "30000000",
                  "currency": "USD"
                },
                "priority": 2,
                "tranche_type": "sequential"
              },
              {
                "coupon": 0.05,
                "current_face": {
                  "amount": "30000000",
                  "currency": "USD"
                },
                "id": "Z",
