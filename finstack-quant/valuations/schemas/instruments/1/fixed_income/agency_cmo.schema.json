                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides."
            },
            "reference_tranche_id": {
              "description": "Reference tranche ID for pricing (which tranche to value)",
              "type": "string"
            },
            "waterfall": {
              "$ref": "#/$defs/CmoWaterfall",
              "description": "Waterfall configuration with tranches"
            }
          },
          "required": [
            "id",
            "deal_name",
            "agency",
            "issue_date",
            "waterfall",
            "reference_tranche_id",
            "discount_curve_id"
          ],
          "type": "object"
        },
        "type": {
          "const": "agency_cmo",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Agency CMO",
  "type": "object"
}
