{
  "$defs": {
    "AgencyProgram": {
      "description": "Agency program enumeration.\n\nIdentifies the government-sponsored enterprise (GSE) or government agency\nthat guarantees the mortgage-backed security.\n\n# GNMA Programs\n\nGinnie Mae has two distinct programs with different payment delay conventions:\n- **GNMA I**: Single-issuer pools with a 14-day stated delay. Payments on the 15th.\n- **GNMA II**: Multi-issuer pools with a 50-day stated delay. Payments on the 20th.\n\nUse `GnmaI` or `GnmaII` to select the appropriate convention. The legacy `Gnma`\nvariant maps to GNMA II (the larger and more actively traded program).",
      "oneOf": [
        {
          "const": "FNMA",
          "description": "Fannie Mae (Federal National Mortgage Association)",
          "type": "string"
        },
        {
          "const": "FHLMC",
          "description": "Freddie Mac (Federal Home Loan Mortgage Corporation)",
          "type": "string"
        },
        {
          "const": "GNMA",
          "description": "Ginnie Mae II (Government National Mortgage Association) - multi-issuer pools.\n\nThis is the legacy variant; equivalent to `GnmaII`. Use `GnmaI` or `GnmaII`\nfor explicit program selection.",
          "type": "string"
        },
        {
          "const": "GNMA_I",
          "description": "Ginnie Mae I - single-issuer pools with 14-day stated delay.\n\nGNMA I securities pay on the 15th of the month following the accrual\nperiod, resulting in a 14-day stated delay from month-end.",
          "type": "string"
        },
        {
          "const": "GNMA_I_I",
          "description": "Ginnie Mae II - multi-issuer pools with 50-day stated delay.\n\nGNMA II securities pay on the 20th of the month following the accrual\nperiod, resulting in a ~50-day stated delay from accrual start. This is\nthe larger and more actively traded GNMA program.",
          "type": "string"
        }
      ]
    },
    "PoolType": {
      "description": "Pool type classification.\n\nDistinguishes between generic (TBA-eligible) pools and specified pools\nwith known characteristics.",
      "oneOf": [
        {
          "const": "generic",
          "description": "Generic pool (TBA-eligible, standard assumptions)",
          "type": "string"
        },
        {
          "const": "specified",
          "description": "Specified pool with known loan-level characteristics",
          "type": "string"
        }
      ]
    }
  },
  "$id": "https://finstack_quant.dev/schemas/instrument/1/fixed_income/agency_mbs_passthrough.schema.json",
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "additionalProperties": false,
  "description": "Agency MBS passthrough security (FNMA, FHLMC, GNMA)",
  "examples": [
    {
      "instrument": {
        "spec": {
          "agency": "FNMA",
          "attributes": {
            "meta": {
              "program": "fnma"
            },
            "tags": [
              "agency",
              "mbs"
            ]
          },
          "current_face": {
            "amount": "950000",
            "currency": "USD"
          },
          "current_factor": 0.95,
          "day_count": "Thirty360",
          "discount_curve_id": "USD-OIS",
          "guarantee_fee_rate": 0.0025,
          "id": "FN-MA1234",
          "issue_date": "2022-01-01",
          "maturity": "2052-01-01",
          "original_face": {
            "amount": "1000000",
            "currency": "USD"
          },
          "pass_through_rate": 0.04,
          "pool_id": "MA1234",
          "pool_type": "generic",
          "prepayment_model": {
            "cpr": 0.06,
            "curve": {
              "curve": "psa",
              "speed_multiplier": 1.0
            }
          },
          "pricing_overrides": {
            "adaptive_bumps": false,
            "call_friction_cents": null,
            "cds_quote_bp": null,
            "credit_spread_bump_bp": null,
            "implied_volatility": null,
            "mc_seed_scenario": null,
            "mean_reversion": null,
            "quoted_clean_price": null,
            "rate_bump_bp": null,
            "rho_bump_decimal": null,
            "spot_bump_pct": null,
            "theta_period": null,
            "tree_steps": null,
            "upfront_payment": null,
            "use_gobet_miri": false,
            "vega_bump_decimal": null,
            "vol_bump_pct": null,
            "vol_surface_extrapolation": "error",
            "ytm_bump_decimal": null
          },
          "servicing_fee_rate": 0.0025,
          "wac": 0.045,
          "wam": 348
        },
        "type": "agency_mbs_passthrough"
      },
      "schema": "finstack_quant.instrument/1"
    }
  ],
  "properties": {
    "instrument": {
      "additionalProperties": false,
      "description": "The Agency Mbs Passthrough instrument definition",
      "properties": {
        "spec": {
          "additionalProperties": false,
          "properties": {
            "agency": {
              "$ref": "#/$defs/AgencyProgram",
              "description": "Agency program (FNMA, FHLMC, GNMA)."
            },
            "attributes": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/attributes.schema.json",
              "default": {},
              "description": "Attributes for scenario selection and tagging.\nAttributes for scenario selection and tagging"
            },
            "current_face": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Current face amount (remaining principal balance)."
            },
            "current_factor": {
              "description": "Current pool factor (current_face / original_face).",
              "format": "double",
              "type": "number"
            },
            "day_count": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/day_count.schema.json",
              "description": "Day count convention for accrual."
            },
            "discount_curve_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Discount curve identifier for pricing."
            },
            "guarantee_fee_rate": {
              "default": 0.0,
              "description": "Guarantee fee rate (annual, as decimal e.g., 0.0025 for 25 bps).\n\nDefaults to `0.0` when omitted.",
              "format": "double",
              "type": "number"
            },
            "id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Unique instrument identifier."
            },
            "issue_date": {
              "description": "Issue date of the pool.",
              "format": "date",
              "type": "string"
            },
            "last_paid_accrual_end": {
              "description": "End date of the latest accrual period whose delayed P&I payment has\nsettled and is already reflected in `current_face`.\n\nWhen omitted, pricing infers the latest paid period from the agency\npayment-delay rule and `as_of`.",
              "type": [
                "string",
                "null"
              ]
            },
            "maturity": {
              "description": "Legal maturity date.",
              "format": "date",
              "type": "string"
            },
            "original_face": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/money.schema.json",
              "description": "Original face amount (initial principal balance)."
            },
            "pass_through_rate": {
              "description": "Pass-through rate (net coupon to investor).",
              "format": "double",
              "type": "number"
            },
            "payment_lag_days": {
              "description": "Optional custom payment delay (overrides agency default).",
              "format": "uint32",
              "minimum": 0,
              "type": [
                "integer",
                "null"
              ]
            },
            "pool_id": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/id.schema.json",
              "description": "Pool identifier (CUSIP or internal pool ID)."
            },
            "pool_type": {
              "$ref": "#/$defs/PoolType",
              "default": "generic",
              "description": "Pool type (generic or specified)."
            },
            "prepayment_model": {
              "$ref": "https://finstack_quant.dev/schemas/cashflow/1/prepayment_model_spec.schema.json",
              "description": "Prepayment model specification."
            },
            "pricing_overrides": {
              "$ref": "https://finstack_quant.dev/schemas/common/1/pricing_overrides.schema.json",
              "default": {
                "adaptive_bumps": false,
                "call_friction_cents": null,
                "cds_act360_include_last_day": false,
                "cds_aod_half_day_bias": false,
                "credit_spread_bump_bp": null,
                "mc_seed_scenario": null,
                "mean_reversion": null,
                "oas_price_basis": "settlement_dirty",
                "oas_quote_compounding": "continuous",
                "rate_bump_bp": null,
                "rho_bump_decimal": null,
                "spot_bump_pct": null,
                "theta_period": null,
                "tree_steps": null,
                "use_gobet_miri": false,
                "vega_bump_decimal": null,
                "vol_bump_pct": null,
                "vol_surface_extrapolation": "error",
                "ytm_bump_decimal": null
              },
              "description": "Pricing overrides (including quoted price for OAS)."
            },
            "servicing_fee_rate": {
              "default": 0.0,
              "description": "Servicing fee rate (annual, as decimal e.g., 0.0025 for 25 bps).\n\nDefaults to `0.0` when omitted.",
              "format": "double",
              "type": "number"
            },
            "wac": {
              "description": "Weighted average coupon (gross rate on underlying mortgages).",
              "format": "double",
              "type": "number"
            },
            "wam": {
              "description": "Remaining weighted average maturity in months as of the valuation\ndate (current WAM, not the original term). Pool age (WALA) for\nseasoning ramps is derived separately from `issue_date`.",
              "format": "uint32",
              "minimum": 0,
              "type": "integer"
            }
          },
          "required": [
            "id",
            "pool_id",
            "agency",
            "original_face",
            "current_face",
            "current_factor",
            "wac",
            "pass_through_rate",
            "wam",
            "issue_date",
            "maturity",
            "prepayment_model",
            "discount_curve_id",
            "day_count"
          ],
          "type": "object"
        },
        "type": {
          "const": "agency_mbs_passthrough",
          "type": "string"
        }
      },
      "required": [
        "type",
        "spec"
      ],
      "type": "object"
    },
    "schema": {
      "const": "finstack_quant.instrument/1",
      "description": "Schema version identifier",
      "type": "string"
    }
  },
  "required": [
    "schema",
    "instrument"
  ],
  "title": "Agency MBS Passthrough",
  "type": "object"
}
